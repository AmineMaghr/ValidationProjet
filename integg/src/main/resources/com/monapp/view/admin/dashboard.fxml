<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.image.*?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.text.*?>

<BorderPane xmlns="http://javafx.com/javafx" xmlns:fx="http://javafx.com/fxml" fx:controller="com.example.app.controllers.AdminController" style="-fx-background-color: #0d1117;">

    <!-- Admin Sidebar -->
    <left>
        <VBox style="-fx-background-color: #0b0f10; -fx-min-width: 250; -fx-padding: 20;" spacing="20">
            <Label text="ADMINISTRATION" style="-fx-text-fill: #18E3A4; -fx-font-size: 20; -fx-font-weight: bold;"/>
            
            <VBox spacing="5">
                <Button text="Dashboard" style="-fx-background-color: #18E3A4; -fx-text-fill: #0b0f10; -fx-alignment: CENTER_LEFT; -fx-padding: 12 15;"/>
                <Button text="Utilisateurs" style="-fx-background-color: #1a1f1e; -fx-text-fill: #fff; -fx-alignment: CENTER_LEFT; -fx-padding: 12 15;"/>
                <Button text="Univers" style="-fx-background-color: #1a1f1e; -fx-text-fill: #fff; -fx-alignment: CENTER_LEFT; -fx-padding: 12 15;"/>
                <Button text="Personnages" style="-fx-background-color: #1a1f1e; -fx-text-fill: #fff; -fx-alignment: CENTER_LEFT; -fx-padding: 12 15;"/>
                <Button text="Œuvres" style="-fx-background-color: #1a1f1e; -fx-text-fill: #fff; -fx-alignment: CENTER_LEFT; -fx-padding: 12 15;"/>
                <Button text="Produits" style="-fx-background-color: #1a1f1e; -fx-text-fill: #fff; -fx-alignment: CENTER_LEFT; -fx-padding: 12 15;"/>
                <Button text="Commandes" style="-fx-background-color: #1a1f1e; -fx-text-fill: #fff; -fx-alignment: CENTER_LEFT; -fx-padding: 12 15;"/>
                <Button text="Défis" style="-fx-background-color: #1a1f1e; -fx-text-fill: #fff; -fx-alignment: CENTER_LEFT; -fx-padding: 12 15;"/>
                <Button text="Quiz" style="-fx-background-color: #1a1f1e; -fx-text-fill: #fff; -fx-alignment: CENTER_LEFT; -fx-padding: 12 15;"/>
            </VBox>
            
            <Region VBox.vgrow="ALWAYS"/>
            
            <Button text="Retour au site" style="-fx-background-color: #2a3139; -fx-text-fill: #fff; -fx-padding: 12 15;"/>
        </VBox>
    </left>

    <!-- Main Content -->
    <center>
        <VBox style="-fx-padding: 30;" spacing="30">
            <Label text="Dashboard Administrateur" style="-fx-text-fill: #fff; -fx-font-size: 28; -fx-font-weight: bold;"/>
            
            <!-- Stats Cards -->
            <HBox spacing="20">
                <VBox style="-fx-background-color: #1a1f1e; -fx-padding: 20; -fx-background-radius: 10;" spacing="10" minWidth="200">
                    <Label text="Utilisateurs" style="-fx-text-fill: #888;"/>
                    <Label text="1,234" style="-fx-text-fill: #fff; -fx-font-size: 32; -fx-font-weight: bold;"/>
                </VBox>
                <VBox style="-fx-background-color: #1a1f1e; -fx-padding: 20; -fx-background-radius: 10;" spacing="10" minWidth="200">
                    <Label text="Univers" style="-fx-text-fill: #888;"/>
                    <Label text="567" style="-fx-text-fill: #fff; -fx-font-size: 32; -fx-font-weight: bold;"/>
                </VBox>
                <VBox style="-fx-background-color: #1a1f1e; -fx-padding: 20; -fx-background-radius: 10;" spacing="10" minWidth="200">
                    <Label text="Commandes" style="-fx-text-fill: #888;"/>
                    <Label text="89" style="-fx-text-fill: #fff; -fx-font-size: 32; -fx-font-weight: bold;"/>
                </VBox>
                <VBox style="-fx-background-color: #1a1f1e; -fx-padding: 20; -fx-background-radius: 10;" spacing="10" minWidth="200">
                    <Label text="Revenus" style="-fx-text-fill: #888;"/>
                    <Label text="4,567€" style="-fx-text-fill: #18E3A4; -fx-font-size: 32; -fx-font-weight: bold;"/>
                </VBox>
            </HBox>

            <!-- Recent Activity -->
            <VBox style="-fx-background-color: #1a1f1e; -fx-padding: 20; -fx-background-radius: 10;" spacing="15">
                <Label text="Activité récente" style="-fx-text-fill: #fff; -fx-font-size: 18; -fx-font-weight: bold;"/>
                
                <VBox spacing="10">
                    <HBox alignment="CENTER_LEFT" spacing="15">
                        <Label text="Nouvel utilisateur" style="-fx-text-fill: #18E3A4;"/>
                        <Label text="john@example.com" style="-fx-text-fill: #fff;"/>
                        <Region HBox.hgrow="ALWAYS"/>
                        <Label text="Il y a 5 min" style="-fx-text-fill: #666;"/>
                    </HBox>
                    <HBox alignment="CENTER_LEFT" spacing="15">
                        <Label text="Nouvelle commande" style="-fx-text-fill: #18E3A4;"/>
                        <Label text="#1234 - 45.00€" style="-fx-text-fill: #fff;"/>
                        <Region HBox.hgrow="ALWAYS"/>
                        <Label text="Il y a 15 min" style="-fx-text-fill: #666;"/>
                    </HBox>
                    <HBox alignment="CENTER_LEFT" spacing="15">
                        <Label text="Nouveau défi créé" style="-fx-text-fill: #18E3A4;"/>
                        <Label text="Défi mensuel" style="-fx-text-fill: #fff;"/>
                        <Region HBox.hgrow="ALWAYS"/>
                        <Label text="Il y a 1h" style="-fx-text-fill: #666;"/>
                    </HBox>
                </VBox>
            </VBox>
        </VBox>
    </center>

</BorderPane>