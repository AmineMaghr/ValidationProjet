<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.image.*?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.text.*?>

<AnchorPane xmlns="http://javafx.com/javafx" xmlns:fx="http://javafx.com/fxml" fx:controller="com.example.app.controllers.AdminController" style="-fx-background-color: #0d1117;">

    <VBox spacing="0" AnchorPane.leftAnchor="250" AnchorPane.rightAnchor="0">
        
        <!-- Header -->
        <HBox style="-fx-background-color: #0b0f10; -fx-padding: 20;" alignment="CENTER_LEFT">
            <Label text="Gestion des commandes" style="-fx-text-fill: #fff; -fx-font-size: 24; -fx-font-weight: bold;"/>
        </HBox>

        <!-- Orders Table -->
        <VBox style="-fx-padding: 20;" spacing="15">
            <TableView fx:id="ordersTable" style="-fx-background-color: #1a1f1e;">
                <columns>
                    <TableColumn text="N° Commande" prefWidth="120"/>
                    <TableColumn text="Client" prefWidth="150"/>
                    <TableColumn text="Date" prefWidth="120"/>
                    <TableColumn text="Montant" prefWidth="100"/>
                    <TableColumn text="Statut" prefWidth="120"/>
                    <TableColumn text="Actions" prefWidth="100"/>
                </columns>
            </TableView>
        </VBox>

    </VBox>

</AnchorPane>