<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.image.*?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.text.*?>

<AnchorPane xmlns="http://javafx.com/javafx" xmlns:fx="http://javafx.com/fxml" fx:controller="com.example.app.controllers.AdminController" style="-fx-background-color: #0d1117;">

    <VBox spacing="0" AnchorPane.leftAnchor="250" AnchorPane.rightAnchor="0">
        
        <!-- Header -->
        <HBox style="-fx-background-color: #0b0f10; -fx-padding: 20;" alignment="CENTER_LEFT">
            <Label text="Gestion des défis" style="-fx-text-fill: #fff; -fx-font-size: 24; -fx-font-weight: bold;"/>
            <Region HBox.hgrow="ALWAYS"/>
            <Button text="+ Créer un défi" style="-fx-background-color: #18E3A4; -fx-text-fill: #0b0f10; -fx-padding: 10 20; -fx-background-radius: 5;"/>
        </HBox>

        <!-- Challenges List -->
        <VBox style="-fx-padding: 20;" spacing="20">
            <HBox spacing="20">
                <VBox style="-fx-background-color: #1a1f1e; -fx-background-radius: 10; -fx-min-width: 350;" spacing="15">
                    <ImageView fitWidth="350" fitHeight="180" style="-fx-background-radius: 10 10 0 0;"/>
                    <VBox style="-fx-padding: 20;" spacing="10">
                        <Label text="Défi Avril 2024" style="-fx-text-fill: #fff; -fx-font-weight: bold; -fx-font-size: 18;"/>
                        <Label text="Description du défi..." style="-fx-text-fill: #888;"/>
                        <HBox spacing="20">
                            <VBox>
                                <Label text="Participants" style="-fx-text-fill: #888;"/>
                                <Label text="15" style="-fx-text-fill: #fff;"/>
                            </VBox>
                            <VBox>
                                <Label text="Statut" style="-fx-text-fill: #888;"/>
                                <Label text="Actif" style="-fx-text-fill: #18E3A4;"/>
                            </VBox>
                        </HBox>
                        <HBox spacing="10">
                            <Button text="Modifier" style="-fx-background-color: #2a3139; -fx-text-fill: #fff; -fx-padding: 8 15;"/>
                            <Button text="Terminer" style="-fx-background-color: #ff6b6b; -fx-text-fill: #fff; -fx-padding: 8 15;"/>
                        </HBox>
                    </VBox>
                </VBox>
            </HBox>
        </VBox>

    </VBox>

</AnchorPane>