<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.text.*?>

<AnchorPane xmlns="http://javafx.com/javafx/17"
            xmlns:fx="http://javafx.com/fxml"
            fx:controller="com.example.app.controllers.ResetPasswordController"
            style="-fx-background-color: #0a0c10;">

    <VBox style="-fx-background-color: linear-gradient(to right, #0f212e, #0a0c10);"
          AnchorPane.leftAnchor="0" AnchorPane.rightAnchor="0" AnchorPane.topAnchor="0">
        <HBox spacing="30" style="-fx-padding: 15 30;" alignment="CENTER_LEFT">
            <HBox spacing="10" alignment="CENTER_LEFT" onMouseClicked="#goToHome" style="-fx-cursor: hand;">
                <Label text="⚡" style="-fx-text-fill: #18E3A4; -fx-font-size: 28px; -fx-font-weight: bold;"/>
                <Label text="MIDGAR" style="-fx-text-fill: #18E3A4; -fx-font-size: 22px; -fx-font-weight: bold;"/>
            </HBox>
            <Region HBox.hgrow="ALWAYS"/>
            <Button text="Connexion" onAction="#goToLogin"
                    style="-fx-background-color: transparent; -fx-border-color: #18E3A4; -fx-text-fill: #18E3A4; -fx-border-radius: 20; -fx-padding: 8 20; -fx-cursor: hand;"/>
        </HBox>
    </VBox>

    <ScrollPane style="-fx-background-color: transparent; -fx-border-color: transparent;"
                AnchorPane.leftAnchor="0" AnchorPane.rightAnchor="0" AnchorPane.topAnchor="80" AnchorPane.bottomAnchor="0">
        <VBox alignment="TOP_CENTER" style="-fx-padding: 30;">
            <VBox maxWidth="440" style="-fx-background-color: #11161c; -fx-background-radius: 24; -fx-border-color: #1a2530; -fx-border-radius: 24;">
                <VBox spacing="10" style="-fx-padding: 30 30 20 30; -fx-background-color: #0f212e; -fx-background-radius: 24 24 0 0;">
                    <Label text="🔑 Réinitialisation" style="-fx-text-fill: #18E3A4; -fx-font-size: 28px; -fx-font-weight: bold;"/>
                    <Label text="Entrez votre nouveau mot de passe" style="-fx-text-fill: #6a7a8a; -fx-font-size: 13px;"/>
                </VBox>
                <Separator style="-fx-background-color: rgba(24,227,164,0.15);"/>
                <VBox spacing="20" style="-fx-padding: 25 30 25 30;">
                    
                    <!-- Champ pour le code/token (caché si pré-rempli) -->
                    <VBox spacing="8" fx:id="codeContainer" visible="true">
                        <Label text="Code de réinitialisation" style="-fx-text-fill: #fff; -fx-font-size: 14px; -fx-font-weight: bold;"/>
                        <TextField fx:id="tokenField" promptText="Collez le code reçu par email ou SMS"
                                   style="-fx-background-color: #1a2530; -fx-text-fill: #fff; -fx-prompt-text-fill: #6a7a8a; -fx-background-radius: 12; -fx-padding: 14; -fx-border-color: #2a3540; -fx-border-radius: 12;"/>
                    </VBox>
                    
                    <VBox spacing="8">
                        <Label text="Nouveau mot de passe" style="-fx-text-fill: #fff; -fx-font-size: 14px; -fx-font-weight: bold;"/>
                        <PasswordField fx:id="newPasswordField" promptText="••••••••"
                                       style="-fx-background-color: #1a2530; -fx-text-fill: #fff; -fx-prompt-text-fill: #6a7a8a; -fx-background-radius: 12; -fx-padding: 14; -fx-border-color: #2a3540; -fx-border-radius: 12;"/>
                    </VBox>
                    <VBox spacing="8">
                        <Label text="Confirmer" style="-fx-text-fill: #fff; -fx-font-size: 14px; -fx-font-weight: bold;"/>
                        <PasswordField fx:id="confirmPasswordField" promptText="••••••••"
                                       style="-fx-background-color: #1a2530; -fx-text-fill: #fff; -fx-prompt-text-fill: #6a7a8a; -fx-background-radius: 12; -fx-padding: 14; -fx-border-color: #2a3540; -fx-border-radius: 12;"/>
                    </VBox>
                    <Label fx:id="messageLabel" wrapText="true" style="-fx-font-size: 12px;" visible="false"/>
                    <Button fx:id="resetBtn" text="Réinitialiser" onAction="#handleResetPassword"
                            style="-fx-background-color: #18E3A4; -fx-text-fill: #0a0c10; -fx-font-weight: bold; -fx-background-radius: 30; -fx-padding: 14; -fx-font-size: 14px; -fx-cursor: hand;"/>
                    <Separator style="-fx-background-color: rgba(24,227,164,0.15);"/>
                    <Button text="← Retour à la connexion" onAction="#goToLogin"
                            style="-fx-background-color: transparent; -fx-border-color: #18E3A4; -fx-text-fill: #18E3A4; -fx-border-radius: 30; -fx-padding: 10; -fx-cursor: hand; -fx-font-weight: bold;"/>
                </VBox>
            </VBox>
        </VBox>
    </ScrollPane>
</AnchorPane>