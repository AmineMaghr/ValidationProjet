<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.image.*?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.text.*?>

<AnchorPane xmlns="http://javafx.com/javafx" xmlns:fx="http://javafx.com/fxml" fx:controller="com.example.app.controllers.ProfileController" style="-fx-background-color: #0d1117;">

    <fx:include source="../partials/header.fxml" AnchorPane.leftAnchor="0" AnchorPane.rightAnchor="0" AnchorPane.topAnchor="0"/>

    <VBox spacing="0" AnchorPane.leftAnchor="0" AnchorPane.rightAnchor="0" AnchorPane.topAnchor="100">

        <!-- Header -->
        <VBox style="-fx-background-color: #0b0f10; -fx-padding: 30 100;">
            <HBox spacing="30">
                <!-- Avatar -->
                <VBox alignment="CENTER">
                    <ImageView fitWidth="150" fitHeight="150" style="-fx-background-color: #1a1f1e; -fx-background-radius: 75;"/>
                    <Button text="Modifier" style="-fx-background-color: #2a3139; -fx-text-fill: #18E3A4; -fx-padding: 5 15; -fx-background-radius: 5;"/>
                </VBox>
                
                <!-- Profile Info -->
                <VBox spacing="10" alignment="CENTER_LEFT">
                    <Label fx:id="usernameLabel" text="Nom d'utilisateur" style="-fx-text-fill: #fff; -fx-font-size: 28; -fx-font-weight: bold;"/>
                    <Label fx:id="emailLabel" text="email@exemple.com" style="-fx-text-fill: #888;"/>
                    <Label text="Membre depuis janvier 2024" style="-fx-text-fill: #666;"/>
                    
                    <HBox spacing="20" alignment="CENTER_LEFT">
                        <VBox alignment="CENTER">
                            <Label text="15" style="-fx-text-fill: #fff; -fx-font-size: 20; -fx-font-weight: bold;"/>
                            <Label text="Univers" style="-fx-text-fill: #888;"/>
                        </VBox>
                        <VBox alignment="CENTER">
                            <Label text="42" style="-fx-text-fill: #fff; -fx-font-size: 20; -fx-font-weight: bold;"/>
                            <Label text="Personnages" style="-fx-text-fill: #888;"/>
                        </VBox>
                        <VBox alignment="CENTER">
                            <Label text="8" style="-fx-text-fill: #fff; -fx-font-size: 20; -fx-font-weight: bold;"/>
                            <Label text="Œuvres" style="-fx-text-fill: #888;"/>
                        </VBox>
                    </HBox>
                </VBox>
                
                <Region HBox.hgrow="ALWAYS"/>
                
                <!-- Action Buttons -->
                <VBox spacing="10" alignment="CENTER_RIGHT">
                    <Button text="Modifier le profil" style="-fx-background-color: #18E3A4; -fx-text-fill: #0b0f10; -fx-font-weight: bold; -fx-padding: 10 20; -fx-background-radius: 5;"/>
                    <Button text="Paramètres" style="-fx-background-color: #2a3139; -fx-text-fill: #fff; -fx-padding: 10 20; -fx-background-radius: 5;"/>
                </VBox>
            </HBox>
        </VBox>

        <!-- Tab Content -->
        <TabPane style="-fx-background-color: #0b0f10; -fx-tab-min-width: 150;">
            <tabs>
                <Tab text="Mes Univers">
                    <ScrollPane style="-fx-background-color: #0d1117;">
                        <VBox style="-fx-padding: 30 100;" spacing="20">
                            <HBox spacing="20">
                                <VBox style="-fx-background-color: #1a1f1e; -fx-background-radius: 10; -fx-min-width: 280;" spacing="10">
                                    <ImageView fitWidth="280" fitHeight="160" style="-fx-background-radius: 10 10 0 0;"/>
                                    <VBox style="-fx-padding: 15;">
                                        <Label text="Nom de l'univers" style="-fx-text-fill: #fff; -fx-font-weight: bold;"/>
                                        <Label text="5 personnages - 3 œuvres" style="-fx-text-fill: #888;"/>
                                    </VBox>
                                </VBox>
                                <VBox style="-fx-background-color: #2a3139; -fx-background-radius: 10; -fx-min-width: 280;" alignment="CENTER">
                                    <Label text="+" style="-fx-text-fill: #18E3A4; -fx-font-size: 36;"/>
                                    <Label text="Créer un univers" style="-fx-text-fill: #18E3A4;"/>
                                </VBox>
                            </HBox>
                        </VBox>
                    </ScrollPane>
                </Tab>
                
                <Tab text="Mes Personnages">
                    <ScrollPane style="-fx-background-color: #0d1117;">
                        <VBox style="-fx-padding: 30 100;" spacing="20">
                            <HBox spacing="20">
                                <VBox style="-fx-background-color: #1a1f1e; -fx-background-radius: 10; -fx-min-width: 200;" spacing="10">
                                    <ImageView fitWidth="200" fitHeight="250" style="-fx-background-radius: 10 10 0 0;"/>
                                    <VBox style="-fx-padding: 10;">
                                        <Label text="Personnage" style="-fx-text-fill: #fff;"/>
                                    </VBox>
                                </VBox>
                                <VBox style="-fx-background-color: #2a3139; -fx-background-radius: 10; -fx-min-width: 200;" alignment="CENTER">
                                    <Label text="+" style="-fx-text-fill: #18E3A4; -fx-font-size: 36;"/>
                                    <Label text="Créer" style="-fx-text-fill: #18E3A4;"/>
                                </VBox>
                            </HBox>
                        </VBox>
                    </ScrollPane>
                </Tab>
                
                <Tab text="Mes Œuvres">
                    <ScrollPane style="-fx-background-color: #0d1117;">
                        <VBox style="-fx-padding: 30 100;" spacing="20">
                            <HBox spacing="20">
                                <VBox style="-fx-background-color: #1a1f1e; -fx-background-radius: 10; -fx-min-width: 250;" spacing="10">
                                    <ImageView fitWidth="250" fitHeight="200" style="-fx-background-radius: 10 10 0 0;"/>
                                    <VBox style="-fx-padding: 10;">
                                        <Label text="Titre de l'œuvre" style="-fx-text-fill: #fff;"/>
                                        <Label text="TYPE" style="-fx-text-fill: #888;"/>
                                    </VBox>
                                </VBox>
                                <VBox style="-fx-background-color: #2a3139; -fx-background-radius: 10; -fx-min-width: 250;" alignment="CENTER">
                                    <Label text="+" style="-fx-text-fill: #18E3A4; -fx-font-size: 36;"/>
                                    <Label text="Créer" style="-fx-text-fill: #18E3A4;"/>
                                </VBox>
                            </HBox>
                        </VBox>
                    </ScrollPane>
                </Tab>
                
                <Tab text="Mes Défis">
                    <ScrollPane style="-fx-background-color: #0d1117;">
                        <VBox style="-fx-padding: 30 100;" spacing="20">
                            <Label text="Aucun défi participé" style="-fx-text-fill: #888;"/>
                        </VBox>
                    </ScrollPane>
                </Tab>
            </tabs>
        </TabPane>

    </VBox>

</AnchorPane>