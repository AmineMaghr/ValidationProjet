<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.media.MediaView?>

<AnchorPane xmlns="http://javafx.com/javafx/17"
            xmlns:fx="http://javafx.com/fxml"
            fx:controller="com.example.app.controllers.AccueilController"
            stylesheets="@accueil.css">

    <!-- ================= VIDEO BACKGROUND – PLEIN ÉCRAN ================= -->
    <MediaView fx:id="mediaView"
               AnchorPane.topAnchor="0"
               AnchorPane.bottomAnchor="0"
               AnchorPane.leftAnchor="0"
               AnchorPane.rightAnchor="0"
               styleClass="video-background"/>

    <!-- ================= OVERLAY – COUVRE TOUTE LA VIDÉO ================= -->
    <Pane styleClass="video-overlay"
          mouseTransparent="true"
          AnchorPane.topAnchor="0"
          AnchorPane.bottomAnchor="0"
          AnchorPane.leftAnchor="0"
          AnchorPane.rightAnchor="0"/>

    <!-- ================= HEADER ================= -->
    <VBox styleClass="header"
          AnchorPane.topAnchor="0"
          AnchorPane.leftAnchor="0"
          AnchorPane.rightAnchor="0">

        <HBox styleClass="header-content"
               spacing="20"
               alignment="CENTER_LEFT">

            <padding>
                <Insets top="15" right="30" bottom="15" left="30"/>
            </padding>

            <!-- LOGO -->
            <HBox styleClass="logo"
                   spacing="10"
                   alignment="CENTER_LEFT"
                   onMouseClicked="#goAccueil">

                <Label text="⚔️"
                       style="-fx-font-size: 24px;"/>

                <Label text="Midgar"
                       style="-fx-font-size: 20px;
                              -fx-font-weight: bold;
                              -fx-text-fill: #18E3A4;"/>
            </HBox>

            <!-- NAVIGATION -->
            <HBox spacing="6"
                   HBox.hgrow="ALWAYS">

                <Button text="Accueil"
                        styleClass="magic-btn"
                        onAction="#goAccueil"/>

                <Button text="Découvrir"
                        styleClass="magic-btn"
                        onAction="#goDiscover"/>

                <Button text="Univers"
                        styleClass="magic-btn"
                        onAction="#goUniverses"/>

                <Button text="Personnages"
                        styleClass="magic-btn"
                        onAction="#goPersonnages"/>

                <Button text="Œuvres"
                        styleClass="magic-btn"
                        onAction="#goOeuvres"/>

                <Button text="Artefacts"
                        styleClass="magic-btn"
                        onAction="#goArtefacts"/>

                <Button text="Boutique"
                        styleClass="magic-btn"
                        onAction="#goShop"/>

                <Button text="Défis"
                        styleClass="magic-btn"
                        onAction="#goChallenges"/>
            </HBox>

            <!-- ACTIONS – AUTH CONTAINER -->
            <HBox fx:id="authContainer"
                  spacing="10"
                  alignment="CENTER_RIGHT"/>

        </HBox>

        <!-- BARRE DE RECHERCHE -->
        <VBox fx:id="searchBarContainer"
              styleClass="search-bar-container"
              visible="false"
              managed="false">

            <HBox styleClass="search-bar-wrapper"
                  spacing="10"
                  alignment="CENTER_LEFT">

                <Label text="🔍"
                       styleClass="search-icon"/>

                <TextField fx:id="searchInput"
                           promptText="Nom d'utilisateur, prénom ou nom..."
                           styleClass="search-bar-input"
                           HBox.hgrow="ALWAYS"/>

                <Button text="✕"
                        styleClass="search-close-btn"
                        onAction="#toggleSearchBar"/>

            </HBox>

            <ListView fx:id="searchResults"
                      styleClass="search-bar-results"
                      visible="false"
                      maxHeight="300"/>

        </VBox>

    </VBox>

    <!-- ================= CONTENU SCROLLABLE ================= -->
    <ScrollPane fitToWidth="true"
                style="-fx-background-color: transparent;"
                AnchorPane.topAnchor="80"
                AnchorPane.bottomAnchor="0"
                AnchorPane.leftAnchor="0"
                AnchorPane.rightAnchor="0">

        <VBox spacing="40"
                style="-fx-background-color: transparent;">

            <!-- ================= HERO ================= -->
            <StackPane styleClass="hero">

                <VBox styleClass="hero-content"
                       alignment="CENTER">

                    <Label text="MIDGAR"
                           styleClass="hero-title"/>

                    <Label text="Créez, partagez et faites vivre vos univers fantasy"
                           styleClass="hero-tagline"
                           wrapText="true"/>

                    <Button text="✨ Commencer le Quiz"
                            styleClass="btn-primary"
                            onAction="#lancerQuiz"/>

                </VBox>

            </StackPane>

            <!-- ================= UNIVERS POPULAIRES ================= -->
            <VBox styleClass="section">

                <Label text="Univers Populaires"
                       styleClass="section-title"/>

                <HBox fx:id="universSlider"
                      spacing="20"
                      alignment="CENTER"/>

                <HBox spacing="20"
                      alignment="CENTER">

                    <Button text="❮"
                            styleClass="slider-nav"
                            onAction="#prevUnivers"/>

                    <Button text="❯"
                            styleClass="slider-nav"
                            onAction="#nextUnivers"/>

                </HBox>

            </VBox>

            <!-- ================= CRÉATIONS RÉCENTES ================= -->
            <VBox styleClass="section">

                <Label text="Créations Récentes"
                       styleClass="section-title"/>

                <HBox fx:id="creationsSlider"
                      spacing="20"
                      alignment="CENTER"/>

                <HBox spacing="20"
                      alignment="CENTER">

                    <Button text="❮"
                            styleClass="slider-nav"
                            onAction="#prevCreation"/>

                    <Button text="❯"
                            styleClass="slider-nav"
                            onAction="#nextCreation"/>

                </HBox>

            </VBox>

            <!-- ================= DÉFIS ================= -->
            <VBox styleClass="section">

                <Label text="Défis"
                       styleClass="section-title"/>

                <TilePane fx:id="defisGrid"
                          styleClass="defis-grid"
                          prefColumns="4"
                          hgap="20"
                          vgap="20"/>

            </VBox>

            <!-- ================= FOOTER ================= -->
            <VBox styleClass="footer"
                   alignment="CENTER"
                   spacing="10">

                <padding>
                    <Insets top="30"
                            right="20"
                            bottom="30"
                            left="20"/>
                </padding>

                <Label text="© 2026 Midgar Fantasy Platform. Tous droits réservés."/>

            </VBox>

        </VBox>

    </ScrollPane>

    <!-- ================= MODAL DÉFI ================= -->
    <StackPane fx:id="defiModal"
               styleClass="modal"
               visible="false"
               managed="false"
               AnchorPane.leftAnchor="0"
               AnchorPane.rightAnchor="0"
               AnchorPane.topAnchor="0"
               AnchorPane.bottomAnchor="0">

        <VBox styleClass="modal-content"
               spacing="15"
               maxWidth="500">

            <Button text="✕"
                    styleClass="modal-close"
                    onAction="#closeDefiModal"/>

            <Label fx:id="modalTitre"
                   styleClass="modal-title"/>

            <HBox spacing="10">
                <Label text="Thème :"
                       style="-fx-font-weight: bold;"/>
                <Label fx:id="modalTheme"/>
            </HBox>

            <Label fx:id="modalDescription"
                   wrapText="true"/>

            <HBox spacing="10">
                <Label text="Début :"
                       style="-fx-font-weight: bold;"/>
                <Label fx:id="modalDebut"/>
            </HBox>

            <HBox spacing="10">
                <Label text="Fin :"
                       style="-fx-font-weight: bold;"/>
                <Label fx:id="modalFin"/>
            </HBox>

            <HBox spacing="10">
                <Label text="Statut :"
                       style="-fx-font-weight: bold;"/>
                <Label fx:id="modalStatut"/>
            </HBox>

            <Button text="Participer"
                    styleClass="btn-primary"
                    onAction="#participerDefi"/>

        </VBox>

    </StackPane>

</AnchorPane>