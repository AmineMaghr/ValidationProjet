<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.image.*?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.text.*?>

<AnchorPane xmlns="http://javafx.com/javafx" xmlns:fx="http://javafx.com/fxml" fx:controller="com.example.app.controllers.RegisterController" style="-fx-background-color: #0d1117;">

    <VBox alignment="CENTER" spacing="0" AnchorPane.leftAnchor="0" AnchorPane.rightAnchor="0" AnchorPane.topAnchor="0" AnchorPane.bottomAnchor="0">
        
        <!-- Header -->
        <HBox alignment="CENTER" style="-fx-background-color: #0b0f10; -fx-padding: 20;">
            <Label text="MIDGAR" style="-fx-text-fill: #18E3A4; -fx-font-size: 28; -fx-font-weight: bold;"/>
        </HBox>

        <!-- Registration Card -->
        <VBox style="-fx-background-color: #1a1f1e; -fx-padding: 40; -fx-background-radius: 10;" 
              spacing="20" alignment="CENTER" maxWidth="600">
            <Label text="Créer un compte" style="-fx-text-fill: #fff; -fx-font-size: 24; -fx-font-weight: bold;"/>
            
            <GridPane hgap="15" vgap="15" maxWidth="500">
                <columnConstraints>
                    <ColumnConstraints minWidth="200"/>
                    <ColumnConstraints minWidth="200"/>
                </columnConstraints>
                
                <!-- Username -->
                <VBox spacing="5" GridPane.columnIndex="0" GridPane.rowIndex="0">
                    <Label text="Pseudo" style="-fx-text-fill: #b0b9b6;"/>
                    <TextField fx:id="usernameField" promptText="Votre pseudo"
                               style="-fx-background-color: #0b0f10; -fx-text-fill: #fff; -fx-border-color: #2a3139; -fx-border-radius: 5; -fx-background-radius: 5; -fx-padding: 10;"/>
                </VBox>
                
                <!-- Email -->
                <VBox spacing="5" GridPane.columnIndex="1" GridPane.rowIndex="0">
                    <Label text="Email" style="-fx-text-fill: #b0b9b6;"/>
                    <TextField fx:id="emailField" promptText="votre@email.com"
                               style="-fx-background-color: #0b0f10; -fx-text-fill: #fff; -fx-border-color: #2a3139; -fx-border-radius: 5; -fx-background-radius: 5; -fx-padding: 10;"/>
                </VBox>
                
                <!-- Password -->
                <VBox spacing="5" GridPane.columnIndex="0" GridPane.rowIndex="1">
                    <Label text="Mot de passe" style="-fx-text-fill: #b0b9b6;"/>
                    <PasswordField fx:id="passwordField" promptText="••••••••"
                                   style="-fx-background-color: #0b0f10; -fx-text-fill: #fff; -fx-border-color: #2a3139; -fx-border-radius: 5; -fx-background-radius: 5; -fx-padding: 10;"/>
                </VBox>
                
                <!-- Confirm Password -->
                <VBox spacing="5" GridPane.columnIndex="1" GridPane.rowIndex="1">
                    <Label text="Confirmer" style="-fx-text-fill: #b0b9b6;"/>
                    <PasswordField fx:id="confirmPasswordField" promptText="••••••••"
                                   style="-fx-background-color: #0b0f10; -fx-text-fill: #fff; -fx-border-color: #2a3139; -fx-border-radius: 5; -fx-background-radius: 5; -fx-padding: 10;"/>
                </VBox>
            </GridPane>

            <!-- Terms Checkbox -->
            <CheckBox text="J'accepte les CGU et la Politique de confidentialité" style="-fx-text-fill: #b0b9b6;"/>

            <!-- Register Button -->
            <Button text="S'inscrire" maxWidth="500" style="-fx-background-color: #18E3A4; -fx-text-fill: #0b0f10; -fx-font-weight: bold; -fx-padding: 12 20; -fx-background-radius: 5;"/>

            <!-- Login Link -->
            <HBox spacing="5" alignment="CENTER">
                <Label text="Déjà un compte?" style="-fx-text-fill: #b0b9b6;"/>
                <Button text="Se connecter" styleClass="link-button"/>
            </HBox>
        </VBox>

    </VBox>

</AnchorPane>