<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>
<?import javafx.geometry.Insets?>

<HBox xmlns="http://javafx.com/javafx" xmlns:fx="http://javafx.com/fxml"
      fx:controller="com.example.app.controllers.HeaderController"
      spacing="20" alignment="CENTER_LEFT"
      styleClass="header, header-content">

    <padding>
        <Insets top="15" right="30" bottom="15" left="30"/>
    </padding>


    <HBox spacing="10" alignment="CENTER_LEFT" styleClass="logo" onMouseClicked="#goAccueil">
        <Label text="⚔️" style="-fx-font-size: 24px;"/>
        <Label text="Midgar" style="-fx-font-size: 20px; -fx-font-weight: bold; -fx-text-fill: #18E3A4;"/>
    </HBox>

    <HBox spacing="5" alignment="CENTER_LEFT" HBox.hgrow="ALWAYS">
        <Button text="Accueil"      styleClass="magic-btn" onAction="#goAccueil"/>
        <Button text="Découvrir"    styleClass="magic-btn" onAction="#goDiscover"/>
        <Button text="Univers"      styleClass="magic-btn" onAction="#goUniverses"/>
        <Button text="Personnages"  styleClass="magic-btn" onAction="#goPersonnages"/>
        <Button text="Œuvre"        styleClass="magic-btn" onAction="#goOeuvres"/>
        <Button text="Artefacts"    styleClass="magic-btn" onAction="#goArtefacts"/>
        <Button text="Boutique"     styleClass="magic-btn" onAction="#goShop"/>
        <Button text="Défis"        styleClass="magic-btn" onAction="#goChallenges"/>
    </HBox>

    <HBox spacing="10" alignment="CENTER_RIGHT">
        <Button text="Assistant" styleClass="btn-secondary" onAction="#openChatbot" style="-fx-padding: 8 18;"/>
        <Button text="Connexion" styleClass="btn-secondary" onAction="#goLogin" style="-fx-padding: 8 18;"/>
        <Button text="S'inscrire" styleClass="btn-primary" onAction="#goRegister" style="-fx-padding: 8 18;"/>
    </HBox>
</HBox>


