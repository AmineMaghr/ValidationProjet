<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.image.*?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.text.*?>


<AnchorPane xmlns="http://javafx.com/javafx/17"
            xmlns:fx="http://javafx.com/fxml"
            fx:controller="com.example.app.controllers.PersonnageController"
            style="-fx-background-color: #0d1117;">

    <fx:include source="partials/header.fxml" AnchorPane.leftAnchor="0" AnchorPane.rightAnchor="0" AnchorPane.topAnchor="0"/>

    <VBox spacing="15" AnchorPane.leftAnchor="0" AnchorPane.rightAnchor="0" AnchorPane.topAnchor="100" AnchorPane.bottomAnchor="0">

        <padding>
            <Insets top="20" right="20" bottom="20" left="20"/>
        </padding>

        <Label text="PERSONNAGES"
               style="-fx-text-fill: #18E3A4; -fx-font-size: 28px; -fx-font-weight: bold;"/>

        <!-- Barre de recherche -->
        <HBox spacing="10">
            <TextField fx:id="searchField" promptText="Rechercher un personnage..." HBox.hgrow="ALWAYS"
                       style="-fx-background-color: #1a1f1e; -fx-text-fill: white; -fx-prompt-text-fill: #888; -fx-border-color: #2a3139; -fx-border-radius: 10;"/>
            <Button text="Rechercher" onAction="#search"
                    style="-fx-background-color: #18E3A4; -fx-text-fill: #0b0f10; -fx-background-radius: 10; -fx-padding: 8 15;"/>
            <Button text="Réinitialiser" onAction="#resetFilters"
                    style="-fx-background-color: transparent; -fx-border-color: #18E3A4; -fx-text-fill: #18E3A4; -fx-background-radius: 10; -fx-padding: 8 15;"/>
            <Button text="Créer" onAction="#createPersonnage"
                    style="-fx-background-color: #18E3A4; -fx-text-fill: #0b0f10; -fx-background-radius: 10; -fx-padding: 8 15;"/>
        </HBox>

        <!-- Filtres -->
        <HBox spacing="20">
            <VBox spacing="5">
                <Label text="Classe" style="-fx-text-fill: #18E3A4; -fx-font-size: 14px; -fx-font-weight: bold;"/>
                <ListView fx:id="classRoleFilter" prefHeight="200" prefWidth="150"
                          style="-fx-background-color: #1a1f1e; -fx-border-color: #2a3139; -fx-border-radius: 10;"/>
            </VBox>
            <VBox spacing="5">
                <Label text="Univers" style="-fx-text-fill: #18E3A4; -fx-font-size: 14px; -fx-font-weight: bold;"/>
                <ListView fx:id="universeFilter" prefHeight="200" prefWidth="150"
                          style="-fx-background-color: #1a1f1e; -fx-border-color: #2a3139; -fx-border-radius: 10;"/>
            </VBox>
            <VBox spacing="5">
                <Label text="Trier par" style="-fx-text-fill: #18E3A4; -fx-font-size: 14px; -fx-font-weight: bold;"/>
                <ComboBox fx:id="sortCombo" prefWidth="150"
                          style="-fx-background-color: #1a1f1e; -fx-text-fill: white; -fx-border-color: #2a3139; -fx-border-radius: 10;"/>
            </VBox>
        </HBox>

        <!-- Liste et formulaire -->
        <SplitPane dividerPositions="0.5" VBox.vgrow="ALWAYS">
            <!-- Liste des personnages -->
            <ListView fx:id="personnageList"
                      style="-fx-background-color: #1a1f1e; -fx-background-radius: 10; -fx-border-color: #2a3139; -fx-border-radius: 10;"/>

            <!-- Formulaire d'édition -->
            <VBox spacing="10" style="-fx-padding: 15; -fx-background-color: #1a1f1e; -fx-background-radius: 10; -fx-border-color: #2a3139; -fx-border-radius: 10;">
                <Label text="DÉTAILS" style="-fx-text-fill: #18E3A4; -fx-font-size: 16px; -fx-font-weight: bold;"/>

                <TextField fx:id="nameField" promptText="Nom"
                           style="-fx-background-color: #2a3139; -fx-text-fill: white; -fx-prompt-text-fill: #888; -fx-border-radius: 10;"/>
                <TextArea fx:id="descriptionArea" promptText="Description" prefHeight="80"
                          style="-fx-background-color: #2a3139; -fx-text-fill: white; -fx-prompt-text-fill: #888; -fx-border-radius: 10;"/>
                <ComboBox fx:id="classRoleCombo" promptText="Classe"
                          style="-fx-background-color: #2a3139; -fx-text-fill: white; -fx-border-radius: 10;"/>
                <ComboBox fx:id="universeCombo" promptText="Univers"
                          style="-fx-background-color: #2a3139; -fx-text-fill: white; -fx-border-radius: 10;"/>

                <HBox spacing="10">
                    <Button fx:id="selectImageBtn" text="Choisir portrait" onAction="#selectImage"
                            style="-fx-background-color: #2a3139; -fx-text-fill: white; -fx-background-radius: 10; -fx-padding: 8 15;"/>
                    <Button fx:id="saveBtn" text="Sauvegarder" onAction="#createPersonnage"
                            style="-fx-background-color: #18E3A4; -fx-text-fill: #0b0f10; -fx-background-radius: 10; -fx-padding: 8 15; -fx-font-weight: bold;"/>
                    <Button fx:id="deleteBtn" text="Supprimer" onAction="#deletePersonnage"
                            style="-fx-background-color: #ff6b6b; -fx-text-fill: white; -fx-background-radius: 10; -fx-padding: 8 15;"/>
                </HBox>

                <ImageView fx:id="portraitView" fitWidth="200" fitHeight="200" preserveRatio="true"
                           style="-fx-background-color: #2a3139; -fx-background-radius: 10;"/>

                <Button text="Retour à l'accueil" onAction="#goAccueil"
                        style="-fx-background-color: transparent; -fx-border-color: #18E3A4; -fx-text-fill: #18E3A4; -fx-background-radius: 10; -fx-padding: 10;"/>
            </VBox>
        </SplitPane>

    </VBox>

</AnchorPane>