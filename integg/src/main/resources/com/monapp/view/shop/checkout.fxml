<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.image.*?>
<?import javafx.scene.shape.Line?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.text.*?>

<AnchorPane xmlns="http://javafx.com/javafx" xmlns:fx="http://javafx.com/fxml" fx:controller="com.example.app.controllers.ShopCheckoutController" style="-fx-background-color: #0d1117;">

    <VBox spacing="0" AnchorPane.leftAnchor="0" AnchorPane.rightAnchor="0" AnchorPane.topAnchor="0" AnchorPane.bottomAnchor="0">

        <StackPane style="-fx-background-color: #0b0f10; -fx-min-height: 150;">
            <VBox alignment="CENTER">
                <Label text="PAIEMENT" style="-fx-text-fill: #fff; -fx-font-size: 36; -fx-font-weight: bold;"/>
            </VBox>
        </StackPane>

        <HBox style="-fx-padding: 40 100;" spacing="40">
            <!-- Checkout Form -->
            <VBox spacing="25" HBox.hgrow="ALWAYS">
                <Label text="Informations de livraison" style="-fx-text-fill: #fff; -fx-font-size: 20; -fx-font-weight: bold;"/>
                
                <GridPane hgap="15" vgap="15">
                    <columnConstraints>
                        <ColumnConstraints minWidth="200"/>
                        <ColumnConstraints minWidth="200"/>
                    </columnConstraints>
                    
                    <VBox spacing="5" GridPane.columnIndex="0" GridPane.rowIndex="0">
                        <Label text="Prénom" style="-fx-text-fill: #b0b9b6;"/>
                        <TextField fx:id="firstNameField" style="-fx-background-color: #1a1f1e; -fx-text-fill: #fff; -fx-border-color: #2a3139; -fx-border-radius: 5; -fx-padding: 10;"/>
                    </VBox>
                    <VBox spacing="5" GridPane.columnIndex="1" GridPane.rowIndex="0">
                        <Label text="Nom" style="-fx-text-fill: #b0b9b6;"/>
                        <TextField fx:id="lastNameField" style="-fx-background-color: #1a1f1e; -fx-text-fill: #fff; -fx-border-color: #2a3139; -fx-border-radius: 5; -fx-padding: 10;"/>
                    </VBox>
                    <VBox spacing="5" GridPane.columnIndex="0" GridPane.columnSpan="2" GridPane.rowIndex="1">
                        <Label text="Adresse" style="-fx-text-fill: #b0b9b6;"/>
                        <TextField fx:id="addressField" style="-fx-background-color: #1a1f1e; -fx-text-fill: #fff; -fx-border-color: #2a3139; -fx-border-radius: 5; -fx-padding: 10;"/>
                    </VBox>
                    <VBox spacing="5" GridPane.columnIndex="0" GridPane.rowIndex="2">
                        <Label text="Ville" style="-fx-text-fill: #b0b9b6;"/>
                        <TextField fx:id="cityField" style="-fx-background-color: #1a1f1e; -fx-text-fill: #fff; -fx-border-color: #2a3139; -fx-border-radius: 5; -fx-padding: 10;"/>
                    </VBox>
                    <VBox spacing="5" GridPane.columnIndex="1" GridPane.rowIndex="2">
                        <Label text="Code postal" style="-fx-text-fill: #b0b9b6;"/>
                        <TextField fx:id="zipCodeField" style="-fx-background-color: #1a1f1e; -fx-text-fill: #fff; -fx-border-color: #2a3139; -fx-border-radius: 5; -fx-padding: 10;"/>
                    </VBox>
                </GridPane>

                <Label text="Informations de paiement" style="-fx-text-fill: #fff; -fx-font-size: 20; -fx-font-weight: bold;"/>
                
                <VBox spacing="15">
                    <VBox spacing="5">
                        <Label text="Numéro de carte" style="-fx-text-fill: #b0b9b6;"/>
                        <TextField fx:id="cardNumberField" promptText="0000 0000 0000 0000" style="-fx-background-color: #1a1f1e; -fx-text-fill: #fff; -fx-border-color: #2a3139; -fx-border-radius: 5; -fx-padding: 10;"/>
                    </VBox>
                    <HBox spacing="15">
                        <VBox spacing="5" HBox.hgrow="ALWAYS">
                            <Label text="Date d'expiration" style="-fx-text-fill: #b0b9b6;"/>
                            <TextField fx:id="expiryDateField" promptText="MM/AA" style="-fx-background-color: #1a1f1e; -fx-text-fill: #fff; -fx-border-color: #2a3139; -fx-border-radius: 5; -fx-padding: 10;"/>
                        </VBox>
                        <VBox spacing="5" HBox.hgrow="ALWAYS">
                            <Label text="CVV" style="-fx-text-fill: #b0b9b6;"/>
                            <TextField fx:id="cvvField" promptText="123" style="-fx-background-color: #1a1f1e; -fx-text-fill: #fff; -fx-border-color: #2a3139; -fx-border-radius: 5; -fx-padding: 10;"/>
                        </VBox>
                    </HBox>
                </VBox>

                <Button fx:id="payButton" text="Payer 74.97€" onAction="#processPayment" style="-fx-background-color: #18E3A4; -fx-text-fill: #0b0f10; -fx-font-weight: bold; -fx-padding: 15; -fx-background-radius: 5;"/>
                <Button text="Retour au panier" onAction="#goBackToCart" style="-fx-background-color: #333; -fx-text-fill: #18E3A4; -fx-border-color: #18E3A4; -fx-font-weight: bold; -fx-padding: 10; -fx-background-radius: 5;"/>
            </VBox>

            <!-- Order Summary -->
            <VBox fx:id="orderSummary" style="-fx-background-color: #1a1f1e; -fx-background-radius: 10; -fx-padding: 25; -fx-min-width: 300;" spacing="20">
                <Label text="Récapitulatif" style="-fx-text-fill: #fff; -fx-font-size: 18; -fx-font-weight: bold;"/>
                
                <VBox fx:id="orderItemsContainer" spacing="10"/>

                <Line stroke="#2a3139"/>

                <HBox>
                    <Label text="Total" style="-fx-text-fill: #fff; -fx-font-weight: bold;"/>
                    <Region HBox.hgrow="ALWAYS"/>
                    <Label fx:id="totalLabel" text="74.97€" style="-fx-text-fill: #18E3A4; -fx-font-size: 20; -fx-font-weight: bold;"/>
                </HBox>
            </VBox>
        </HBox>

    </VBox>

</AnchorPane>