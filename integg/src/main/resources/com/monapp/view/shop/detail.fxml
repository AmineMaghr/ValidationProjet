<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.image.*?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.text.*?>

<AnchorPane xmlns="http://javafx.com/javafx" xmlns:fx="http://javafx.com/fxml" fx:controller="com.example.app.controllers.ShopDetailController" style="-fx-background-color: #0d1117;">

    <VBox spacing="0" AnchorPane.leftAnchor="0" AnchorPane.rightAnchor="0" AnchorPane.topAnchor="0" AnchorPane.bottomAnchor="0">

        <!-- Product Detail -->
        <HBox style="-fx-padding: 50 100;" spacing="50" HBox.hgrow="ALWAYS">
            <!-- Product Image -->
            <VBox spacing="15" minWidth="400">
                <ImageView fx:id="productImageView" fitWidth="400" fitHeight="400" style="-fx-background-color: #1a1f1e; -fx-background-radius: 10;"/>
                <HBox spacing="10">
                    <ImageView fitWidth="80" fitHeight="80" style="-fx-background-color: #2a3139; -fx-background-radius: 5;"/>
                    <ImageView fitWidth="80" fitHeight="80" style="-fx-background-color: #2a3139; -fx-background-radius: 5;"/>
                    <ImageView fitWidth="80" fitHeight="80" style="-fx-background-color: #2a3139; -fx-background-radius: 5;"/>
                </HBox>
            </VBox>

            <!-- Product Info -->
            <VBox spacing="20" HBox.hgrow="ALWAYS">
                <Label fx:id="productNameLabel" text="Nom du produit" style="-fx-text-fill: #fff; -fx-font-size: 32; -fx-font-weight: bold;"/>
                <Label fx:id="productCategoryLabel" text="Catégorie" style="-fx-text-fill: #888;"/>

                <Label fx:id="productPriceLabel" text="29.99€" style="-fx-text-fill: #18E3A4; -fx-font-size: 28; -fx-font-weight: bold;"/>

                <Label fx:id="productDescriptionLabel" text="Description du produit..." style="-fx-text-fill: #b0b9b6;" wrapText="true" maxWidth="400"/>

                <!-- Options -->
                <VBox spacing="10">
                    <Label text="Taille" style="-fx-text-fill: #fff;"/>
                    <HBox spacing="10">
                        <Button text="S" style="-fx-background-color: #2a3139; -fx-text-fill: #fff; -fx-padding: 8 15;"/>
                        <Button text="M" style="-fx-background-color: #18E3A4; -fx-text-fill: #0b0f10; -fx-padding: 8 15;"/>
                        <Button text="L" style="-fx-background-color: #2a3139; -fx-text-fill: #fff; -fx-padding: 8 15;"/>
                        <Button text="XL" style="-fx-background-color: #2a3139; -fx-text-fill: #fff; -fx-padding: 8 15;"/>
                    </HBox>
                </VBox>

                <HBox spacing="15">
                    <Spinner fx:id="quantitySpinner" style="-fx-background-color: #2a3139; -fx-text-fill: #fff;"/>
                    <Button fx:id="addToCartButton" text="Ajouter au panier" onAction="#addToCart" style="-fx-background-color: #18E3A4; -fx-text-fill: #0b0f10; -fx-font-weight: bold; -fx-padding: 15 30;"/>
                </HBox>

                <HBox alignment="CENTER" spacing="10">
                    <Button text="Retour" onAction="#goBack" style="-fx-background-color: #333; -fx-text-fill: #18E3A4; -fx-border-color: #18E3A4; -fx-padding: 10 20;"/>
                    <Button text="Voir le panier" onAction="#goCart" style="-fx-background-color: #18E3A4; -fx-text-fill: #0b0f10; -fx-font-weight: bold; -fx-padding: 10 20;"/>
                </HBox>
            </VBox>
        </HBox>

        <!-- Related Products -->
        <VBox style="-fx-background-color: #0b0f10; -fx-padding: 40 100;" spacing="20">
            <Label text="Produits similaires" style="-fx-text-fill: #fff; -fx-font-size: 24; -fx-font-weight: bold;"/>
            <HBox fx:id="relatedProductsContainer" spacing="20"/>
        </VBox>

    </VBox>

</AnchorPane>