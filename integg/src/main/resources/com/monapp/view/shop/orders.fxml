<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.VBox?>

<AnchorPane xmlns="http://javafx.com/javafx" xmlns:fx="http://javafx.com/fxml" fx:controller="com.example.app.controllers.ShopOrdersController" style="-fx-background-color: #0d1117;">

    <VBox spacing="0" AnchorPane.leftAnchor="0" AnchorPane.rightAnchor="0" AnchorPane.topAnchor="0" AnchorPane.bottomAnchor="0">

        <VBox style="-fx-background-color: #0b0f10; -fx-padding: 24 32;" spacing="8">
            <Label text="MES COMMANDES" style="-fx-text-fill: #fff; -fx-font-size: 28; -fx-font-weight: bold;"/>
            <Label text="Historique de vos achats" style="-fx-text-fill: #b0b9b6; -fx-font-size: 14;"/>
        </VBox>

        <ScrollPane fitToWidth="true" style="-fx-background-color: transparent; -fx-border-color: transparent;">
            <VBox fx:id="ordersContainer" spacing="16" style="-fx-padding: 24 32;"/>
        </ScrollPane>

        <VBox style="-fx-padding: 0 32 24 32;">
            <Button text="Retour boutique" onAction="#goBack" style="-fx-background-color: #18E3A4; -fx-text-fill: #0b0f10; -fx-font-weight: bold; -fx-padding: 12 18;"/>
        </VBox>
    </VBox>

</AnchorPane>
