<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ListView?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<BorderPane xmlns="http://javafx.com/javafx/17.0.1" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.example.app.controllers.UniversesController" stylesheets="/com/example/app/css/style.css">
    <top>
        <HBox spacing="15" style="-fx-padding: 15; -fx-background-color: #0b0f10; -fx-border-color: #18E3A4; -fx-border-width: 0 0 1 0;">
            <Button text="← Retour" style="-fx-background-color: transparent; -fx-text-fill: #18E3A4; -fx-font-weight: bold;" onAction="#goHome" />
            <Label text="Univers" style="-fx-text-fill: #18E3A4; -fx-font-size: 18; -fx-font-weight: bold;" />
            <TextField fx:id="searchField" promptText="Rechercher..." style="-fx-control-inner-background: #1A1F1E; -fx-text-fill: #E6FFF6;" />
            <Button text="🔍 Rechercher" style="-fx-background-color: #18E3A4; -fx-text-fill: #000; -fx-font-weight: bold;" onAction="#handleSearch" />
            <Button text="+ Créer" style="-fx-background-color: #18E3A4; -fx-text-fill: #000; -fx-font-weight: bold;" onAction="#handleCreate" />
        </HBox>
    </top>

    <center>
        <ScrollPane style="-fx-background-color: #1A1F1E; -fx-padding: 0;" fitToWidth="true">
            <ListView fx:id="universesList" style="-fx-background-color: #1A1F1E; -fx-padding: 20;" prefHeight="800" />
        </ScrollPane>
    </center>
</BorderPane>

