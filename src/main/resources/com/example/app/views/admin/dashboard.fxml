<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.Tab?>
<?import javafx.scene.control.TabPane?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.control.ListView?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<BorderPane xmlns="http://javafx.com/javafx/17.0.1" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.example.app.controllers.AdminController" stylesheets="/com/example/app/css/style.css">
    <top>
        <HBox spacing="15" style="-fx-padding: 15; -fx-background-color: #0b0f10; -fx-border-color: #18E3A4; -fx-border-width: 0 0 1 0;">
            <Button text="← Retour" style="-fx-background-color: transparent; -fx-text-fill: #18E3A4; -fx-font-weight: bold;" onAction="#goHome" />
            <Label text="Admin Dashboard" style="-fx-text-fill: #FF0000; -fx-font-size: 18; -fx-font-weight: bold;" />
        </HBox>
    </top>

    <center>
        <TabPane style="-fx-background-color: #1A1F1E;" tabClosingPolicy="UNAVAILABLE">
            <!-- Users Tab -->
            <Tab text="Utilisateurs" style="-fx-text-fill: #E6FFF6;">
                <VBox spacing="10" style="-fx-padding: 20;">
                    <HBox spacing="10">
                        <TextField fx:id="userSearchField" promptText="Rechercher..." style="-fx-control-inner-background: #0D0F0F; -fx-text-fill: #E6FFF6;" />
                        <Button text="🔍 Rechercher" style="-fx-background-color: #18E3A4; -fx-text-fill: #000;" onAction="#handleUserSearch" />
                    </HBox>
                    <ListView fx:id="usersList" style="-fx-background-color: #0D0F0F;" prefHeight="400" />
                </VBox>
            </Tab>

            <!-- Universes Tab -->
            <Tab text="Univers" style="-fx-text-fill: #E6FFF6;">
                <VBox spacing="10" style="-fx-padding: 20;">
                    <HBox spacing="10">
                        <TextField fx:id="universeSearchField" promptText="Rechercher..." style="-fx-control-inner-background: #0D0F0F; -fx-text-fill: #E6FFF6;" />
                        <Button text="🔍 Rechercher" style="-fx-background-color: #18E3A4; -fx-text-fill: #000;" onAction="#handleUniverseSearch" />
                    </HBox>
                    <ListView fx:id="universesList" style="-fx-background-color: #0D0F0F;" prefHeight="400" />
                </VBox>
            </Tab>

            <!-- Oeuvres Tab -->
            <Tab text="Oeuvres" style="-fx-text-fill: #E6FFF6;">
                <VBox spacing="10" style="-fx-padding: 20;">
                    <ListView fx:id="oeuvresList" style="-fx-background-color: #0D0F0F;" prefHeight="400" />
                </VBox>
            </Tab>

            <!-- Defis Tab -->
            <Tab text="Défis" style="-fx-text-fill: #E6FFF6;">
                <VBox spacing="10" style="-fx-padding: 20;">
                    <ListView fx:id="defisList" style="-fx-background-color: #0D0F0F;" prefHeight="400" />
                </VBox>
            </Tab>

            <!-- Admin Actions Tab -->
            <Tab text="Actions Administrateur" style="-fx-text-fill: #E6FFF6;">
                <VBox spacing="10" style="-fx-padding: 20;">
                    <Label text="Actions Administrateur" textFill="#18E3A4" style="-fx-font-weight: bold;" />
                    <Button text="🏠 Retour à l'accueil" style="-fx-background-color: #18E3A4; -fx-text-fill: #000;" onAction="#goHome" />
                    <Button text="🛒 Gestion Boutique" style="-fx-background-color: #18E3A4; -fx-text-fill: #000;" onAction="#goShopAdmin" />
                </VBox>
            </Tab>
        </TabPane>
    </center>
</BorderPane>
