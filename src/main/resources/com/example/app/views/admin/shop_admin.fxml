<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ListView?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.control.Tab?>
<?import javafx.scene.control.TabPane?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<BorderPane xmlns="http://javafx.com/javafx/17.0.1" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.example.app.controllers.AdminShopController" stylesheets="/com/example/app/css/style.css">
    <top>
        <HBox spacing="15" style="-fx-padding: 15; -fx-background-color: #0b0f10; -fx-border-color: #18E3A4; -fx-border-width: 0 0 1 0;">
            <Button text="← Retour" style="-fx-background-color: transparent; -fx-text-fill: #18E3A4; -fx-font-weight: bold;" onAction="#goBack" />
            <Label text="Administration Boutique" style="-fx-text-fill: #FF0000; -fx-font-size: 18; -fx-font-weight: bold;" />
        </HBox>
    </top>

    <center>
        <TabPane style="-fx-background-color: #1A1F1E;" tabClosingPolicy="UNAVAILABLE">
            <!-- Commandes Tab -->
            <Tab text="Commandes" style="-fx-text-fill: #E6FFF6;">
                <VBox spacing="15" style="-fx-padding: 20;">
                    <HBox spacing="10">
                        <TextField fx:id="searchField" promptText="Rechercher par référence..." style="-fx-control-inner-background: #0D0F0F; -fx-text-fill: #E6FFF6;" />
                        <Button text="🔍" style="-fx-background-color: #18E3A4; -fx-text-fill: #000;" onAction="#handleSearch" />
                        <Button text="🔄 Actualiser" style="-fx-background-color: #18E3A4; -fx-text-fill: #000;" onAction="#handleRefresh" />
                    </HBox>

                    <HBox spacing="20" style="-fx-padding: 0 0 10 0;">
                        <VBox spacing="10" style="-fx-hgrow: always;">
                            <Label text="Liste des Commandes" textFill="#18E3A4" style="-fx-font-weight: bold;" />
                            <ListView fx:id="commandesList" style="-fx-background-color: #0D0F0F;" prefHeight="400" />
                        </VBox>

                        <VBox fx:id="detailPanel" spacing="10" style="-fx-padding: 20; -fx-border-color: #18E3A4; -fx-border-width: 1; -fx-border-radius: 8; -fx-background-color: rgba(24, 227, 164, 0.05);" managed="false" visible="false">
                            <Label text="Détails de la Commande" textFill="#18E3A4" style="-fx-font-weight: bold;" />

                            <VBox spacing="5">
                                <Label text="Référence:" textFill="#B0B9B6" />
                                <Label fx:id="commandeRef" textFill="#E6FFF6" style="-fx-font-weight: bold;" />
                            </VBox>

                            <VBox spacing="5">
                                <Label text="Date:" textFill="#B0B9B6" />
                                <Label fx:id="commandeDate" textFill="#E6FFF6" />
                            </VBox>

                            <VBox spacing="5">
                                <Label text="Montant:" textFill="#B0B9B6" />
                                <Label fx:id="commandeMontant" textFill="#E6FFF6" style="-fx-font-weight: bold;" />
                            </VBox>

                            <VBox spacing="5">
                                <Label text="Statut:" textFill="#B0B9B6" />
                                <Label fx:id="commandeStatut" textFill="#E6FFF6" />
                            </VBox>

                            <HBox spacing="10" style="-fx-padding: 15 0 0 0;">
                                <Button text="Modifier" style="-fx-background-color: #18E3A4; -fx-text-fill: #000; -fx-font-weight: bold;" onAction="#handleEditCommande" />
                                <Button text="Supprimer" style="-fx-background-color: #FF6B6B; -fx-text-fill: #FFF; -fx-font-weight: bold;" onAction="#handleDeleteCommande" />
                            </HBox>
                        </VBox>
                    </HBox>
                </VBox>
            </Tab>

            <!-- Analytics Tab -->
            <Tab text="Analytics" style="-fx-text-fill: #E6FFF6;">
                <VBox spacing="20" style="-fx-padding: 20;">
                    <Label text="Analytics de la Boutique" textFill="#18E3A4" style="-fx-font-size: 16; -fx-font-weight: bold;" />
                    <Label text="Fonctionnalité en développement..." textFill="#B0B9B6" />
                    <Button text="Voir les Analytics" style="-fx-background-color: #18E3A4; -fx-text-fill: #000;" onAction="#handleAnalytics" />
                </VBox>
            </Tab>

            <!-- Automation History Tab -->
            <Tab text="Historique Automation" style="-fx-text-fill: #E6FFF6;">
                <VBox spacing="20" style="-fx-padding: 20;">
                    <Label text="Historique d'Automatisation" textFill="#18E3A4" style="-fx-font-size: 16; -fx-font-weight: bold;" />
                    <Label text="Fonctionnalité en développement..." textFill="#B0B9B6" />
                    <Button text="Voir l'Historique" style="-fx-background-color: #18E3A4; -fx-text-fill: #000;" onAction="#handleAutomationHistory" />
                </VBox>
            </Tab>

            <!-- Stock Predictions Tab -->
            <Tab text="Prédictions Stock" style="-fx-text-fill: #E6FFF6;">
                <VBox spacing="20" style="-fx-padding: 20;">
                    <Label text="Prédictions de Stock" textFill="#18E3A4" style="-fx-font-size: 16; -fx-font-weight: bold;" />
                    <Label text="Fonctionnalité en développement..." textFill="#B0B9B6" />
                    <Button text="Calculer Prédictions" style="-fx-background-color: #18E3A4; -fx-text-fill: #000;" onAction="#handleStockPredictions" />
                </VBox>
            </Tab>
        </TabPane>
    </center>
</BorderPane>
