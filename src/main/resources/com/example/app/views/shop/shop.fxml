<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ListView?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<BorderPane xmlns="http://javafx.com/javafx/17.0.1" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.example.app.controllers.ShopController" stylesheets="/com/example/app/css/style.css">
    <top>
        <HBox spacing="15" style="-fx-padding: 15; -fx-background-color: #0b0f10; -fx-border-color: #18E3A4; -fx-border-width: 0 0 1 0;">
            <Button text="← Retour" style="-fx-background-color: transparent; -fx-text-fill: #18E3A4; -fx-font-weight: bold;" onAction="#goHome" />
            <Label text="Boutique" style="-fx-text-fill: #18E3A4; -fx-font-size: 18; -fx-font-weight: bold;" />
        </HBox>
    </top>

    <center>
        <ScrollPane style="-fx-background-color: #1A1F1E; -fx-padding: 0;" fitToWidth="true">
            <VBox spacing="20" style="-fx-padding: 30;">
                <!-- Title -->
                <Label text="Boutique Midgar" style="-fx-text-fill: #18E3A4; -fx-font-size: 20; -fx-font-weight: bold;" />
                <Label text="Achetez des articles et des bonus pour personnaliser votre expérience" style="-fx-text-fill: #B0B9B6; -fx-font-size: 12;" />

                <!-- Products List -->
                <ListView fx:id="productsList" style="-fx-background-color: #0D0F0F; -fx-padding: 10;" prefHeight="600" />
            </VBox>
        </ScrollPane>
    </center>
</BorderPane>

