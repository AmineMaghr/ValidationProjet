<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.image.*?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.text.*?>

<AnchorPane xmlns="http://javafx.com/javafx/17"
            stylesheets="@defis.css"
            xmlns:fx="http://javafx.com/fxml"
            fx:controller="com.example.app.controllers.DefiController"
            style="-fx-background-color: #0d1117;">

    <!-- HEADER INTÉGRÉ -->
    <VBox styleClass="header" AnchorPane.leftAnchor="0" AnchorPane.rightAnchor="0" AnchorPane.topAnchor="0">
        <HBox styleClass="header-content" spacing="20" alignment="CENTER_LEFT">
            <padding>
                <Insets top="15" right="30" bottom="15" left="30"/>
            </padding>

            <!-- Logo -->
            <HBox styleClass="logo" spacing="10" alignment="CENTER_LEFT" onMouseClicked="#goAccueil">
                <Label text="⚔️" style="-fx-font-size: 24px;"/>
                <Label text="Midgar" style="-fx-font-size: 20px; -fx-font-weight: bold; -fx-text-fill: #18E3A4;"/>
            </HBox>

            <!-- Navigation -->
            <HBox styleClass="nav-menu" spacing="5" HBox.hgrow="ALWAYS">
                <Button text="Accueil" styleClass="magic-btn" onAction="#goAccueil"/>
                <Button text="Découvrir" styleClass="magic-btn" onAction="#goDiscover"/>
                <Button text="Univers" styleClass="magic-btn" onAction="#goUniverses"/>
                <Button text="Personnages" styleClass="magic-btn" onAction="#goPersonnages"/>
                <Button text="Œuvre" styleClass="magic-btn" onAction="#goOeuvres"/>
                <Button text="Artefacts" styleClass="magic-btn" onAction="#goArtefacts"/>
                <Button text="Boutique" styleClass="magic-btn" onAction="#goShop"/>
                <Button text="Défis" styleClass="magic-btn active" onAction="#goChallenges"/>
            </HBox>

            <!-- Auth buttons -->
            <HBox fx:id="authContainer" spacing="10" alignment="CENTER_RIGHT"/>
        </HBox>
    </VBox>

    <ScrollPane fitToWidth="true" style="-fx-background: transparent; -fx-background-color: transparent;"
                AnchorPane.leftAnchor="0" AnchorPane.rightAnchor="0" AnchorPane.topAnchor="80" AnchorPane.bottomAnchor="0">

        <VBox spacing="0" style="-fx-background-color: transparent;">

            <!-- Hero Banner -->
            <StackPane style="-fx-background-color: linear-gradient(to bottom, #18E3A4, #0d1117); -fx-min-height: 250;">
                <VBox alignment="CENTER" spacing="20">
                    <Label text="DÉFIS CRÉATIFS" style="-fx-text-fill: #0b0f10; -fx-font-size: 48; -fx-font-weight: bold;"/>
                    <Label text="Participez à des défis mensuels et gagnez des récompenses!" style="-fx-text-fill: #0b0f10; -fx-font-size: 16;"/>

                    <!-- Barre de recherche -->
                    <HBox alignment="CENTER" spacing="10" style="-fx-padding: 10 0 0 0;">
                        <TextField fx:id="searchField" promptText="Rechercher un défi..."
                                   style="-fx-background-color: #1a1f1e; -fx-text-fill: #fff; -fx-border-color: #2a3139; -fx-border-radius: 20; -fx-pref-width: 300; -fx-padding: 8 15;"/>
                        <Button text="🔍" onAction="#search"
                                style="-fx-background-color: #18E3A4; -fx-background-radius: 20; -fx-padding: 8 12; -fx-cursor: hand;"/>
                    </HBox>
                </VBox>
            </StackPane>

            <!-- Section principale -->
            <VBox style="-fx-padding: 40 100;" spacing="30">

                <!-- DÉFIS ACTIFS -->
                <Label text="🔥 Défis Actifs" style="-fx-text-fill: #18E3A4; -fx-font-size: 24; -fx-font-weight: bold;"/>

                <TilePane fx:id="activeDefisGrid" prefColumns="2" hgap="20" vgap="20" style="-fx-alignment: TOP_LEFT;"/>

                <!-- DÉFIS PASSÉS -->
                <Label text="✨ Défis Passés" style="-fx-text-fill: #18E3A4; -fx-font-size: 24; -fx-font-weight: bold; -fx-margin-top: 30;"/>

                <TilePane fx:id="pastDefisGrid" prefColumns="2" hgap="20" vgap="20" style="-fx-alignment: TOP_LEFT;"/>

                <!-- Message vide -->
                <Label fx:id="emptyMessage" text="Aucun défi trouvé" style="-fx-text-fill: #888; -fx-font-size: 16; -fx-alignment: center;"
                       visible="false" managed="false" maxWidth="Infinity"/>

            </VBox>

            <!-- Section Admin (visible uniquement pour les admins) -->
            <VBox fx:id="adminSection" style="-fx-padding: 40 100;" spacing="20" visible="false" managed="false">
                <Label text="Administration" style="-fx-text-fill: #18E3A4; -fx-font-size: 24; -fx-font-weight: bold;"/>

                <HBox spacing="20">
                    <TextField fx:id="adminTitreField" promptText="Titre du défi"
                               style="-fx-background-color: #1a1f1e; -fx-text-fill: #fff; -fx-border-color: #2a3139; -fx-border-radius: 8; -fx-padding: 8;"/>
                    <TextField fx:id="adminThemeField" promptText="Thème"
                               style="-fx-background-color: #1a1f1e; -fx-text-fill: #fff; -fx-border-color: #2a3139; -fx-border-radius: 8; -fx-padding: 8;"/>
                    <DatePicker fx:id="adminDateDebutPicker" promptText="Date début"
                                style="-fx-background-color: #1a1f1e; -fx-text-fill: #fff;"/>
                    <DatePicker fx:id="adminDateFinPicker" promptText="Date fin"
                                style="-fx-background-color: #1a1f1e; -fx-text-fill: #fff;"/>
                    <Button text="Créer" onAction="#createDefi"
                            style="-fx-background-color: #18E3A4; -fx-text-fill: #0b0f10; -fx-font-weight: bold; -fx-padding: 8 16; -fx-background-radius: 8;"/>
                </HBox>
            </VBox>

        </VBox>
    </ScrollPane>

</AnchorPane>