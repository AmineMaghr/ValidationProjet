<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.image.*?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.text.*?>
<?import javafx.scene.shape.Circle?>

<AnchorPane xmlns="http://javafx.com/javafx/17"
            xmlns:fx="http://javafx.com/fxml"
            fx:controller="com.example.app.controllers.ProfileController"
            stylesheets="@../accueil.css"
            style="-fx-background-color: #0a0c10;">

    <!-- HEADER FIXE -->
    <VBox styleClass="header" AnchorPane.leftAnchor="0" AnchorPane.rightAnchor="0" AnchorPane.topAnchor="0">

        <!-- Barre de navigation -->
        <HBox styleClass="header-content" spacing="20" alignment="CENTER_LEFT">
            <padding>
                <Insets top="15" right="30" bottom="15" left="30"/>
            </padding>

            <!-- Logo -->
            <HBox styleClass="logo" spacing="10" alignment="CENTER_LEFT" onMouseClicked="#goAccueil">
                <Label text="⚔️" style="-fx-font-size: 24px;" styleClass="float"/>
                <Label text="Midgar" style="-fx-font-size: 20px; -fx-font-weight: bold; -fx-text-fill: #18E3A4;"/>
            </HBox>

            <!-- Navigation -->
            <HBox styleClass="nav-menu" spacing="5" HBox.hgrow="ALWAYS">
                <Button text="Accueil" styleClass="magic-btn" onAction="#goAccueil"/>
                <Button text="Découvrir" styleClass="magic-btn" onAction="#goDiscover"/>
                <Button text="Univers" styleClass="magic-btn" onAction="#goUniverses"/>
                <Button text="Personnages" styleClass="magic-btn" onAction="#goPersonnages"/>
                <Button text="Œuvre" styleClass="magic-btn" onAction="#goOeuvres"/>
                <Button text="Artefacts" styleClass="magic-btn" onAction="#goArtefacts"/>
                <Button text="Boutique" styleClass="magic-btn" onAction="#goShop"/>
                <Button text="Défis" styleClass="magic-btn" onAction="#goChallenges"/>
            </HBox>

            <!-- Auth buttons -->
            <HBox fx:id="authContainer" spacing="10" alignment="CENTER_RIGHT"/>
        </HBox>

        <!-- Barre de recherche -->
        <VBox fx:id="searchBarContainer" styleClass="search-bar-container" visible="false">
            <HBox styleClass="search-bar-wrapper" spacing="10" alignment="CENTER_LEFT">
                <Label text="🔍" styleClass="search-icon"/>
                <TextField fx:id="searchInput" promptText="Nom d'utilisateur, prénom ou nom..."
                           styleClass="search-bar-input" HBox.hgrow="ALWAYS"/>
                <Button text="✕" styleClass="search-close-btn" onAction="#toggleSearchBar"/>
            </HBox>
            <ListView fx:id="searchResults" styleClass="search-bar-results" visible="false" maxHeight="300"/>
        </VBox>
    </VBox>

    <!-- Contenu principal -->
    <ScrollPane style="-fx-background-color: transparent; -fx-border-color: transparent;"
                AnchorPane.leftAnchor="0" AnchorPane.rightAnchor="0" AnchorPane.topAnchor="80" AnchorPane.bottomAnchor="0">
        <VBox spacing="0" style="-fx-background-color: #0a0c10;">
            
            <!-- Header du profil -->
            <VBox style="-fx-background-color: #0f212e; -fx-padding: 40 100;">
                <HBox spacing="40" alignment="CENTER_LEFT">
                    
                    <!-- Avatar avec bordure circulaire -->
                    <VBox alignment="CENTER" spacing="15">
                        <StackPane>
                            <Circle radius="75" fill="#1a2530" stroke="#18E3A4" strokeWidth="3"/>
                            <ImageView fx:id="avatarImage" fitWidth="140" fitHeight="140" 
                                       style="-fx-background-radius: 70;"/>
                        </StackPane>
                        <Button text="Modifier l'avatar" onAction="#handleEditProfile"
                                style="-fx-background-color: #2a3540; -fx-text-fill: #18E3A4; -fx-padding: 8 20; -fx-background-radius: 20; -fx-cursor: hand;"/>
                    </VBox>
                    
                    <!-- Informations utilisateur -->
                    <VBox spacing="12" alignment="CENTER_LEFT">
                        <Label fx:id="usernameLabel" text="Nom d'utilisateur" 
                               style="-fx-text-fill: #18E3A4; -fx-font-size: 28px; -fx-font-weight: bold;"/>
                        <Label fx:id="fullNameLabel" text="Prénom Nom" 
                               style="-fx-text-fill: #b0b9b6; -fx-font-size: 16px;"/>
                        <Label fx:id="emailLabel" text="email@exemple.com" 
                               style="-fx-text-fill: #6a7a8a; -fx-font-size: 14px;"/>
                        <Label fx:id="memberSinceLabel" text="Membre depuis" 
                               style="-fx-text-fill: #6a7a8a; -fx-font-size: 12px;"/>
                        
                        <!-- Statistiques -->
                        <HBox spacing="30" alignment="CENTER_LEFT" style="-fx-padding: 10 0 0 0;">
                            <VBox alignment="CENTER" spacing="5">
                                <Label fx:id="oeuvresCountLabel" text="0" 
                                       style="-fx-text-fill: #fff; -fx-font-size: 22px; -fx-font-weight: bold;"/>
                                <Label text="Œuvres" style="-fx-text-fill: #6a7a8a; -fx-font-size: 12px;"/>
                            </VBox>
                            <VBox alignment="CENTER" spacing="5">
                                <Label fx:id="artefactsCountLabel" text="0" 
                                       style="-fx-text-fill: #fff; -fx-font-size: 22px; -fx-font-weight: bold;"/>
                                <Label text="Artefacts" style="-fx-text-fill: #6a7a8a; -fx-font-size: 12px;"/>
                            </VBox>
                            <VBox alignment="CENTER" spacing="5">
                                <Label fx:id="favoritesCountLabel" text="0" 
                                       style="-fx-text-fill: #fff; -fx-font-size: 22px; -fx-font-weight: bold;"/>
                                <Label text="Favoris" style="-fx-text-fill: #6a7a8a; -fx-font-size: 12px;"/>
                            </VBox>
                        </HBox>
                    </VBox>
                    
                    <Region HBox.hgrow="ALWAYS"/>
                    
                    <!-- Boutons d'action -->
                    <VBox spacing="12" alignment="CENTER_RIGHT">
                        <Button text="✏️ Éditer le profil" onAction="#handleEditProfile"
                                style="-fx-background-color: #18E3A4; -fx-text-fill: #0a0c10; -fx-font-weight: bold; -fx-padding: 12 25; -fx-background-radius: 25; -fx-cursor: hand;"/>
                        <Button text="🔑 Changer mot de passe" onAction="#handleChangePassword"
                                style="-fx-background-color: #2a3540; -fx-text-fill: #fff; -fx-padding: 12 25; -fx-background-radius: 25; -fx-cursor: hand;"/>
                        <Button fx:id="adminBtn" text="🛡️ Administration" onAction="#goToAdmin" visible="false"
                                style="-fx-background-color: #FFA726; -fx-text-fill: #0a0c10; -fx-font-weight: bold; -fx-padding: 12 25; -fx-background-radius: 25; -fx-cursor: hand;"/>
                        <Button text="🚪 Déconnexion" onAction="#handleLogout"
                                style="-fx-background-color: transparent; -fx-border-color: #EF5350; -fx-text-fill: #EF5350; -fx-border-radius: 25; -fx-padding: 12 25; -fx-cursor: hand;"/>
                    </VBox>
                </HBox>
            </VBox>

            <!-- Onglets -->
            <TabPane fx:id="contentTabPane" style="-fx-background-color: transparent; -fx-tab-min-height: 45; -fx-padding: 0 100;" VBox.vgrow="ALWAYS">
                
                <Tab text="📚 Mes Œuvres" closable="false">
                    <VBox spacing="20" style="-fx-padding: 30 0;">
                        <TilePane fx:id="oeuvresGrid" prefColumns="3" hgap="20" vgap="20" 
                                  style="-fx-background-color: transparent;"/>
                        <Label fx:id="noOeuvresLabel" text="Aucune œuvre créée" 
                               style="-fx-text-fill: #6a7a8a; -fx-font-size: 14px;" visible="false"/>
                    </VBox>
                </Tab>
                
                <Tab text="⚡ Mes Artefacts" closable="false">
                    <VBox spacing="20" style="-fx-padding: 30 0;">
                        <TilePane fx:id="artefactsGrid" prefColumns="3" hgap="20" vgap="20" 
                                  style="-fx-background-color: transparent;"/>
                    </VBox>
                </Tab>
                
                <Tab text="❤️ Mes Favoris" closable="false">
                    <VBox spacing="20" style="-fx-padding: 30 0;">
                        <Label text="Favoris - Œuvres" style="-fx-text-fill: #18E3A4; -fx-font-size: 18px; -fx-font-weight: bold;"/>
                        <TilePane fx:id="favoriteOeuvresGrid" prefColumns="3" hgap="20" vgap="20" 
                                  style="-fx-background-color: transparent;"/>
                        <Label text="Favoris - Artefacts" style="-fx-text-fill: #18E3A4; -fx-font-size: 18px; -fx-font-weight: bold; -fx-padding: 20 0 0 0;"/>
                        <TilePane fx:id="favoriteArtefactsGrid" prefColumns="3" hgap="20" vgap="20" 
                                  style="-fx-background-color: transparent;"/>
                    </VBox>
                </Tab>
                
            </TabPane>
            
        </VBox>
    </ScrollPane>
    
</AnchorPane>