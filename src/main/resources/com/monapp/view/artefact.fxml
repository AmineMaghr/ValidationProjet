<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.image.*?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.text.*?>

<BorderPane xmlns="http://javafx.com/javafx" xmlns:fx="http://javafx.com/fxml" fx:controller="com.example.app.controllers.ArtefactController" style="-fx-background-color: #0d1117;">

    <!-- Sidebar gauche -->
    <left>
        <fx:include source="partials/sidebar.fxml"/>
    </left>

    <!-- Contenu principal -->
    <center>
        <StackPane fx:id="contentArea">
        <!-- VUE LISTE -->
        <VBox fx:id="listView" spacing="15" style="-fx-padding: 20; -fx-background-color: #0d1117;">
            <padding>
                <Insets top="20" right="20" bottom="20" left="20"/>
            </padding>

            <Label text="ARTEFACTS"
                   style="-fx-text-fill: #18E3A4; -fx-font-size: 28px; -fx-font-weight: bold;"/>

            <!-- Barre de recherche -->
            <HBox spacing="10">
                <TextField fx:id="searchField" promptText="Rechercher un artefact..." HBox.hgrow="ALWAYS"
                           style="-fx-background-color: #1a1f1e; -fx-text-fill: white; -fx-prompt-text-fill: #888;"/>
                <ComboBox fx:id="typeFilter" promptText="Type" style="-fx-background-color: #1a1f1e; -fx-text-fill: white;"/>
                <CheckBox fx:id="myItemsCheckbox" text="Mes artefacts" style="-fx-text-fill: white;"/>
                <Button text="Chercher" style="-fx-background-color: #18E3A4; -fx-text-fill: #0b0f10; -fx-background-radius: 10; -fx-padding: 8 15;"/>
                <Button text="Créer" fx:id="createBtn" style="-fx-background-color: #18E3A4; -fx-text-fill: #0b0f10; -fx-background-radius: 10; -fx-padding: 8 15;"/>
            </HBox>

            <Label fx:id="resultCount" text="0 artefacts trouvés" style="-fx-text-fill: #888; -fx-font-size: 12px;"/>

            <!-- Grille d'artefacts -->
            <FlowPane fx:id="artefactsGrid" hgap="20" vgap="20" style="-fx-padding: 10;" VBox.vgrow="ALWAYS">
                <VBox style="-fx-background-color: #1a1f1e; -fx-background-radius: 10; -fx-min-width: 200;" spacing="10">
                    <ImageView fitWidth="200" fitHeight="150" style="-fx-background-radius: 10 10 0 0;"/>
                    <VBox style="-fx-padding: 10;">
                        <Label text="Artefact" style="-fx-text-fill: #fff; -fx-font-weight: bold;"/>
                        <Label text="Description..." style="-fx-text-fill: #888; -fx-font-size: 11px;"/>
                    </VBox>
                </VBox>
            </FlowPane>

            <!-- État vide -->
            <VBox fx:id="emptyState" alignment="CENTER" style="-fx-padding: 40;">
                <Label text="Aucun artefact trouvé" style="-fx-text-fill: #888; -fx-font-size: 16px;"/>
            </VBox>

            <Button text="Retourner au page d'accueil" onAction="#goHome"
                    style="-fx-background-color: transparent; -fx-border-color: #18E3A4; -fx-text-fill: #18E3A4; -fx-background-radius: 10; -fx-padding: 10 20;"/>
        </VBox>

        <!-- VUE FORMULAIRE -->
        <VBox fx:id="formView" spacing="10" style="-fx-padding: 20; -fx-background-color: #0d1117;" visible="false">
            <Label text="CRÉER UN ARTEFACT" style="-fx-text-fill: #18E3A4; -fx-font-size: 24px; -fx-font-weight: bold;"/>
            
            <TextField fx:id="nameField" promptText="Nom" style="-fx-background-color: #1a1f1e; -fx-text-fill: white; -fx-prompt-text-fill: #888;"/>
            <ComboBox fx:id="typeCombo" promptText="Type" style="-fx-background-color: #1a1f1e; -fx-text-fill: white;"/>
            <TextField fx:id="universeField" promptText="Univers" style="-fx-background-color: #1a1f1e; -fx-text-fill: white; -fx-prompt-text-fill: #888;"/>
            <TextArea fx:id="originsArea" promptText="Origines" prefHeight="80" style="-fx-background-color: #1a1f1e; -fx-text-fill: white; -fx-prompt-text-fill: #888;"/>
            <TextArea fx:id="powersArea" promptText="Pouvoirs" prefHeight="80" style="-fx-background-color: #1a1f1e; -fx-text-fill: white; -fx-prompt-text-fill: #888;"/>
            <ComboBox fx:id="rarityCombo" promptText="Rareté" style="-fx-background-color: #1a1f1e; -fx-text-fill: white;"/>
            
            <Button fx:id="selectImageBtn" text="Choisir une image" style="-fx-background-color: #1a1f1e; -fx-text-fill: white; -fx-background-radius: 10; -fx-padding: 8 15;"/>
            <ImageView fx:id="formImageView" fitWidth="200" fitHeight="150" style="-fx-background-color: #1a1f1e; -fx-background-radius: 10;"/>
            
            <HBox spacing="10">
                <Button fx:id="submitBtn" text="Créer" style="-fx-background-color: #18E3A4; -fx-text-fill: #0b0f10; -fx-background-radius: 10; -fx-padding: 8 15; -fx-font-weight: bold;"/>
                <Button fx:id="cancelBtn" text="Annuler" style="-fx-background-color: transparent; -fx-border-color: #18E3A4; -fx-text-fill: #18E3A4; -fx-background-radius: 10; -fx-padding: 8 15;"/>
            </HBox>

            <Label fx:id="formError" text="" style="-fx-text-fill: #ff6b6b;"/>
            
            <Button text="Retourner au page d'accueil" onAction="#goHome"
                    style="-fx-background-color: transparent; -fx-border-color: #18E3A4; -fx-text-fill: #18E3A4; -fx-background-radius: 10; -fx-padding: 10 20;"/>
        </VBox>

        <!-- VUE DÉTAIL -->
        <VBox fx:id="detailView" spacing="10" style="-fx-padding: 20; -fx-background-color: #0d1117;" visible="false">
            <Label text="DÉTAILS DE L'ARTEFACT" style="-fx-text-fill: #18E3A4; -fx-font-size: 24px; -fx-font-weight: bold;"/>
            
            <Label fx:id="nameLabel" style="-fx-text-fill: #fff; -fx-font-size: 18px; -fx-font-weight: bold;"/>
            <Label fx:id="typeLabel" style="-fx-text-fill: #18E3A4;"/>
            <Label fx:id="universeLabel" style="-fx-text-fill: #888;"/>
            <Label fx:id="rarityLabel" style="-fx-text-fill: #18E3A4;"/>
            
            <ImageView fx:id="detailImageView" fitWidth="300" fitHeight="200" style="-fx-background-color: #1a1f1e; -fx-background-radius: 10;"/>
            
            <TextArea fx:id="originsDetailArea" promptText="Origines" prefHeight="80" editable="false"
                      style="-fx-background-color: #1a1f1e; -fx-text-fill: white;"/>
            <TextArea fx:id="powersDetailArea" promptText="Pouvoirs" prefHeight="80" editable="false"
                      style="-fx-background-color: #1a1f1e; -fx-text-fill: white;"/>
            
            <Label text="COMMENTAIRES" style="-fx-text-fill: #18E3A4; -fx-font-size: 14px; -fx-font-weight: bold;"/>
            <TextArea fx:id="commentArea" promptText="Ajouter un commentaire..." prefHeight="60"
                      style="-fx-background-color: #1a1f1e; -fx-text-fill: white; -fx-prompt-text-fill: #888;"/>
            <Button fx:id="addCommentBtn" text="Ajouter commentaire"
                    style="-fx-background-color: #18E3A4; -fx-text-fill: #0b0f10; -fx-background-radius: 10; -fx-padding: 8 15;"/>
            <ListView fx:id="commentList" prefHeight="100" style="-fx-background-color: #1a1f1e; -fx-background-radius: 10;"/>
            
            <HBox spacing="10">
                <Button fx:id="editBtn" text="Éditer" style="-fx-background-color: #18E3A4; -fx-text-fill: #0b0f10; -fx-background-radius: 10; -fx-padding: 8 15;"/>
                <Button fx:id="deleteBtn" text="Supprimer" style="-fx-background-color: #ff6b6b; -fx-text-fill: white; -fx-background-radius: 10; -fx-padding: 8 15;"/>
            </HBox>

            <Label fx:id="formTitle" text="" style="-fx-text-fill: #18E3A4;"/>

            <Button text="Retourner au page d'accueil" onAction="#goHome"
                    style="-fx-background-color: transparent; -fx-border-color: #18E3A4; -fx-text-fill: #18E3A4; -fx-background-radius: 10; -fx-padding: 10 20;"/>
        </VBox>
    </StackPane>
    </center>

</BorderPane>