<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.image.*?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.text.*?>

<AnchorPane xmlns="http://javafx.com/javafx" xmlns:fx="http://javafx.com/fxml" fx:controller="com.midgar.controller.ImageUploadController" style="-fx-background-color: #0d1117;">

    <VBox alignment="CENTER" spacing="30" AnchorPane.leftAnchor="0" AnchorPane.rightAnchor="0" AnchorPane.topAnchor="0" AnchorPane.bottomAnchor="0">
        
        <Label text="Téléverser une image" style="-fx-text-fill: #fff; -fx-font-size: 28; -fx-font-weight: bold;"/>
        
        <VBox style="-fx-background-color: #1a1f1e; -fx-border-color: #2a3139; -fx-border-width: 2; -fx-border-style: dashed; -fx-border-radius: 10; -fx-padding: 60;" alignment="CENTER">
            <Label text="+" style="-fx-text-fill: #18E3A4; -fx-font-size: 48;"/>
            <Label text="Glissez votre image ici ou cliquez pour parcourir" style="-fx-text-fill: #888;"/>
        </VBox>

        <Button text="Téléverser" style="-fx-background-color: #18E3A4; -fx-text-fill: #0b0f10; -fx-font-weight: bold; -fx-padding: 12 25;"/>

    </VBox>

</AnchorPane>