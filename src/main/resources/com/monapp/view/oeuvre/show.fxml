<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.image.*?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.text.*?>

<AnchorPane xmlns="http://javafx.com/javafx" xmlns:fx="http://javafx.com/fxml" fx:controller="com.example.app.controllers.OeuvreController" style="-fx-background-color: #0d1117;">

    <fx:include source="../partials/header.fxml" AnchorPane.leftAnchor="0" AnchorPane.rightAnchor="0" AnchorPane.topAnchor="0"/>

    <VBox spacing="0" AnchorPane.leftAnchor="0" AnchorPane.rightAnchor="0" AnchorPane.topAnchor="100">

        <HBox style="-fx-padding: 40 100;" spacing="40">
            <ImageView fitWidth="500" fitHeight="500" style="-fx-background-color: #1a1f1e; -fx-background-radius: 10;"/>

            <VBox spacing="20" HBox.hgrow="ALWAYS">
                <Label text="Titre de l'œuvre" style="-fx-text-fill: #fff; -fx-font-size: 28; -fx-font-weight: bold;"/>
                <Label text="Par Username" style="-fx-text-fill: #888;"/>

                <VBox spacing="10">
                    <Label text="Description" style="-fx-text-fill: #fff; -fx-font-weight: bold;"/>
                    <Label text="Description de l'œuvre..." style="-fx-text-fill: #b0b9b6;" wrapText="true" maxWidth="400"/>
                </VBox>

                <HBox spacing="15">
                    <Button text="Modifier" style="-fx-background-color: #18E3A4; -fx-text-fill: #0b0f10; -fx-font-weight: bold; -fx-padding: 12 20;"/>
                    <Button text="Supprimer" style="-fx-background-color: #ff6b6b; -fx-text-fill: #fff; -fx-padding: 12 20;"/>
                </HBox>
            </VBox>
        </HBox>

    </VBox>

</AnchorPane>