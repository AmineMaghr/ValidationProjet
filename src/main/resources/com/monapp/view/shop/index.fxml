<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.image.*?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.text.*?>
<?import javafx.scene.shape.*?>

<AnchorPane xmlns="http://javafx.com/javafx" xmlns:fx="http://javafx.com/fxml" fx:controller="com.example.app.controllers.ShopController" style="-fx-background-color: #0d1117;">

    <VBox fx:id="siteContent" spacing="0" AnchorPane.leftAnchor="0" AnchorPane.rightAnchor="0" AnchorPane.topAnchor="0" AnchorPane.bottomAnchor="0">

        <fx:include source="../partials/header.fxml" />

        <!-- MAIN CONTENT -->
        <VBox fx:id="main" style="-fx-padding: 0; -fx-background-color: linear-gradient(135deg, #0d1117 0%, #1a1f1e 100%);">
            <VBox fx:id="shopSection" style="-fx-min-height: 100vh; -fx-padding: 3rem 0; -fx-border-radius: 16px; -fx-margin: 2rem auto; -fx-max-width: 1200px; -fx-border-color: rgba(24, 227, 164, 0.1); -fx-border-width: 1;">
                <VBox fx:id="container" style="-fx-padding: 0 2rem;">
                    <!-- HEADER SECTION -->
                    <HBox style="-fx-justify-content: space-between; -fx-align-items: flex-start; -fx-margin-bottom: 3rem;" alignment="CENTER_LEFT" spacing="2rem">
                        <VBox spacing="0.5rem">
                            <Label text="BOUTIQUE" style="-fx-text-fill: white; -fx-font-size: 3rem; -fx-font-weight: bold;"/>
                            <Label text="Découvrez nos produits fantastiques" style="-fx-text-fill: #999; -fx-font-size: 1.1rem;"/>
                        </VBox>
                        <HBox spacing="1rem" alignment="CENTER">
                            <Button text="+ Ajouter un produit" style="-fx-background-color: #18E3A4; -fx-text-fill: #000; -fx-padding: 0.6rem 1.2rem; -fx-background-radius: 8;" onAction="#addProduct"/>
                            <Button text="🛒 Panier" style="-fx-background-color: #18E3A4; -fx-text-fill: #000; -fx-padding: 0.6rem 1.2rem; -fx-background-radius: 8;" onAction="#goCart"/>
                            <Button text="📋 Mes commandes" style="-fx-background-color: transparent; -fx-text-fill: #18E3A4; -fx-border-color: #18E3A4; -fx-border-width: 2; -fx-padding: 0.6rem 1.2rem; -fx-background-radius: 8;" onAction="#goOrders"/>
                        </HBox>
                    </HBox>

                    <!-- SEARCH & FILTERS ROW -->
                    <HBox spacing="2rem" style="-fx-margin-bottom: 3rem;" alignment="TOP_LEFT">
                        <!-- SIDEBAR -->
                        <VBox fx:id="sidebar" style="-fx-flex: 0 0 300px; -fx-width: 300px; -fx-max-width: 300px; -fx-background-color: #1a1f1e; -fx-padding: 1.5rem; -fx-border-radius: 8; -fx-border-color: #333; -fx-border-width: 1;">
                            <VBox spacing="1rem">
                                <!-- Search Input -->
                                <TextField fx:id="searchField" promptText="Chercher..." style="-fx-background-color: #2a2f2e; -fx-text-fill: white; -fx-border-color: #333; -fx-border-radius: 4; -fx-padding: 0.75rem;"/>

                                <!-- Type Filter -->
                                <VBox spacing="0.75rem">
                                    <Label text="TYPE DE PRODUIT" style="-fx-text-fill: #18E3A4; -fx-font-weight: bold;"/>
                                    <ComboBox fx:id="typeFilter" style="-fx-background-color: #2a2f2e; -fx-text-fill: white; -fx-border-color: #333; -fx-border-radius: 4; -fx-padding: 0.75rem;">
                                        <items>
                                            <FXCollections fx:factory="observableArrayList">
                                                <String fx:value="Tous les types"/>
                                            </FXCollections>
                                        </items>
                                    </ComboBox>
                                </VBox>

                                <!-- Sort -->
                                <VBox spacing="0.75rem">
                                    <Label text="TRI" style="-fx-text-fill: #18E3A4; -fx-font-weight: bold;"/>
                                    <ComboBox fx:id="sortFilter" style="-fx-background-color: #2a2f2e; -fx-text-fill: white; -fx-border-color: #333; -fx-border-radius: 4; -fx-padding: 0.75rem;">
                                        <items>
                                            <FXCollections fx:factory="observableArrayList">
                                                <String fx:value="Récent"/>
                                                <String fx:value="Prix (bas → haut)"/>
                                                <String fx:value="Prix (haut → bas)"/>
                                                <String fx:value="Nom (A-Z)"/>
                                                <String fx:value="Stock (plus disponible)"/>
                                            </FXCollections>
                                        </items>
                                    </ComboBox>
                                </VBox>

                                <!-- Buttons -->
                                <VBox spacing="0.5rem">
                                    <Button text="🔍 Rechercher" style="-fx-background-color: #18E3A4; -fx-text-fill: #000; -fx-padding: 0.75rem; -fx-border-radius: 4;" onAction="#handleSearch"/>
                                    <Button text="✕ Réinitialiser" style="-fx-background-color: transparent; -fx-text-fill: #18E3A4; -fx-border-color: #18E3A4; -fx-border-width: 2; -fx-padding: 0.75rem; -fx-border-radius: 4;" onAction="#resetFilters"/>
                                </VBox>
                            </VBox>
                        </VBox>

                        <!-- PRODUCTS GRID -->
                        <VBox fx:id="productsArea" spacing="2rem" HBox.hgrow="ALWAYS">
                            <Label text="PRODUITS" style="-fx-text-fill: white; -fx-font-size: 1.5rem; -fx-font-weight: bold;"/>

                            <ScrollPane fx:id="productsScroll" style="-fx-background-color: transparent; -fx-border-color: transparent;" fitToWidth="true">
                                <FlowPane fx:id="productsGrid" hgap="2rem" vgap="2rem" style="-fx-padding: 1rem; -fx-background-color: transparent;"/>
                            </ScrollPane>
                        </VBox>
                    </HBox>
                </VBox>
            </VBox>
        </VBox>

        <!-- FOOTER -->
        <VBox fx:id="footer" style="-fx-background-color: rgba(13, 15, 15, 0.5); -fx-padding: 3rem 0; -fx-margin-top: 4rem; -fx-border-radius: 16px; -fx-border-color: rgba(24, 227, 164, 0.1); -fx-border-width: 1 0 0 0;">
            <VBox style="-fx-alignment: center; -fx-padding: 0 2rem;">
                <Label text="&copy; 2026 Midgar Fantasy Platform. Créez, partagez, vivez la magie." style="-fx-text-fill: #B0B9B6; -fx-text-alignment: center;"/>
            </VBox>
        </VBox>

    </VBox>

</AnchorPane>
