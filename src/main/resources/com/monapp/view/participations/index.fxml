<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>
<?import javafx.geometry.Insets?>


<AnchorPane xmlns="http://javafx.com/javafx/17"
            xmlns:fx="http://javafx.com/fxml"
            fx:controller="com.example.app.controllers.ParticipationController"
            style="-fx-background-color: #0d1117;">

    <fx:include source="../partials/header.fxml" AnchorPane.leftAnchor="0" AnchorPane.rightAnchor="0" AnchorPane.topAnchor="0"/>

    <VBox spacing="15" AnchorPane.leftAnchor="0" AnchorPane.rightAnchor="0" AnchorPane.topAnchor="100" AnchorPane.bottomAnchor="0">

        <padding>
            <Insets top="20" right="20" bottom="20" left="20"/>
        </padding>

        <Label text="GESTION DES PARTICIPATIONS"
               style="-fx-text-fill: #18E3A4; -fx-font-size: 24px; -fx-font-weight: bold;"/>

        <HBox spacing="10">
            <Button text="Rafraîchir" onAction="#refresh"
                    style="-fx-background-color: #18E3A4; -fx-text-fill: #0b0f10; -fx-background-radius: 10; -fx-padding: 8 15;"/>
            <Button text="Retour à l'accueil" onAction="#goAccueil"
                    style="-fx-background-color: transparent; -fx-border-color: #18E3A4; -fx-text-fill: #18E3A4; -fx-background-radius: 10; -fx-padding: 8 15;"/>
        </HBox>

        <SplitPane dividerPositions="0.6" VBox.vgrow="ALWAYS">

            <!-- Tableau des participations -->
            <VBox spacing="10">
                <Label text="Liste des participations" style="-fx-text-fill: white; -fx-font-weight: bold;"/>
                <TableView fx:id="participationTable" prefHeight="400">
                    <columns>
                        <TableColumn fx:id="colId" text="ID" prefWidth="50"/>
                        <TableColumn fx:id="colDefi" text="Défi" prefWidth="150"/>
                        <TableColumn fx:id="colUser" text="Utilisateur" prefWidth="120"/>
                        <TableColumn fx:id="colDescription" text="Description" prefWidth="200"/>
                        <TableColumn fx:id="colArtworkId" text="ID Œuvre" prefWidth="70"/>
                        <TableColumn fx:id="colStatut" text="Statut" prefWidth="100"/>
                        <TableColumn fx:id="colDateSoumission" text="Date" prefWidth="150"/>
                    </columns>
                </TableView>
            </VBox>

            <!-- Formulaire d'édition -->
            <VBox spacing="10" style="-fx-padding: 15; -fx-background-color: #1a1f1e; -fx-background-radius: 10;">

                <Label text="DÉTAILS" style="-fx-text-fill: #18E3A4; -fx-font-size: 16px; -fx-font-weight: bold;"/>

                <Label text="Défi:" style="-fx-text-fill: #888;"/>
                <ComboBox fx:id="defiCombo" prefWidth="200"/>

                <Label text="Utilisateur:" style="-fx-text-fill: #888;"/>
                <ComboBox fx:id="userCombo" prefWidth="200"/>

                <Label text="Description:" style="-fx-text-fill: #888;"/>
                <TextArea fx:id="descriptionArea" prefHeight="80"/>

                <Label text="ID Œuvre:" style="-fx-text-fill: #888;"/>
                <TextField fx:id="artworkIdField"/>

                <Label text="Statut:" style="-fx-text-fill: #888;"/>
                <ComboBox fx:id="statutCombo" prefWidth="150"/>

                <HBox spacing="10">
                    <Button fx:id="saveBtn" text="Créer" onAction="#saveParticipation"
                            style="-fx-background-color: #18E3A4; -fx-text-fill: #0b0f10; -fx-background-radius: 10; -fx-padding: 8 15;"/>
                    <Button fx:id="deleteBtn" text="Supprimer" onAction="#deleteParticipation"
                            style="-fx-background-color: #ff6b6b; -fx-text-fill: white; -fx-background-radius: 10; -fx-padding: 8 15;"/>
                    <Button fx:id="cancelBtn" text="Annuler" onAction="#cancelEdit"
                            style="-fx-background-color: transparent; -fx-border-color: #888; -fx-text-fill: #888; -fx-background-radius: 10; -fx-padding: 8 15;"/>
                </HBox>

                <Separator style="-fx-background-color: #2a3139;"/>

                <Label text="INFORMATIONS" style="-fx-text-fill: #18E3A4; -fx-font-size: 14px; -fx-font-weight: bold;"/>
                <Label text="Défi:" style="-fx-text-fill: #888;"/>
                <Label fx:id="detailDefiLabel" style="-fx-text-fill: white;"/>
                <Label text="Utilisateur:" style="-fx-text-fill: #888;"/>
                <Label fx:id="detailUserLabel" style="-fx-text-fill: white;"/>
                <Label text="Description:" style="-fx-text-fill: #888;"/>
                <Label fx:id="detailDescriptionLabel" style="-fx-text-fill: white;" wrapText="true"/>
                <Label text="ID Œuvre:" style="-fx-text-fill: #888;"/>
                <Label fx:id="detailArtworkLabel" style="-fx-text-fill: white;"/>
                <Label text="Statut:" style="-fx-text-fill: #888;"/>
                <Label fx:id="detailStatutLabel" style="-fx-text-fill: white;"/>
                <Label text="Date de soumission:" style="-fx-text-fill: #888;"/>
                <Label fx:id="detailDateLabel" style="-fx-text-fill: white;"/>

            </VBox>
        </SplitPane>

        <Label fx:id="errorLabel" style="-fx-text-fill: #ff4444;" visible="false"/>

    </VBox>

</AnchorPane>