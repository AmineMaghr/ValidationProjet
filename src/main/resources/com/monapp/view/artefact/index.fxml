<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.text.*?>
<?import javafx.scene.effect.*?>

<BorderPane xmlns="http://javafx.com/javafx/17"
            xmlns:fx="http://javafx.com/fxml"
            fx:controller="com.example.app.controllers.ArtefactController"
            style="-fx-background-color: #0a0c10;">

    <top>
        <VBox>
            <HBox style="-fx-background-color: #0d1117; -fx-padding: 8 20;" alignment="CENTER_LEFT">
                <Label text="MIDGAR" style="-fx-text-fill: #18E3A4; -fx-font-size: 22; -fx-font-weight: bold;"/>
                <Region HBox.hgrow="ALWAYS"/>
                <HBox spacing="15">
                    <Label text="FR" style="-fx-text-fill: #666; -fx-font-size: 12;"/>
                    <Label text="EUR" style="-fx-text-fill: #666; -fx-font-size: 12;"/>
                </HBox>
            </HBox>

            <HBox style="-fx-background-color: #0d1117; -fx-padding: 12 20; -fx-border-color: #1a1f2e; -fx-border-width: 0 0 1 0;" alignment="CENTER">
                <Label text="MIDGAR" style="-fx-text-fill: #18E3A4; -fx-font-size: 18; -fx-font-weight: 800;" onMouseClicked="#goAccueil"/>
                <Region HBox.hgrow="ALWAYS"/>
                <HBox spacing="25">
                    <Button text="Accueil" style="-fx-background-color: transparent; -fx-text-fill: #8b949e; -fx-font-size: 14; -fx-padding: 6 0;" onAction="#goAccueil"/>
                    <Button text="Découvrir" style="-fx-background-color: transparent; -fx-text-fill: #8b949e; -fx-font-size: 14; -fx-padding: 6 0;" onAction="#goDiscover"/>
                    <Button text="Univers" style="-fx-background-color: transparent; -fx-text-fill: #8b949e; -fx-font-size: 14; -fx-padding: 6 0;" onAction="#goUniverses"/>
                    <Button text="Personnages" style="-fx-background-color: transparent; -fx-text-fill: #8b949e; -fx-font-size: 14; -fx-padding: 6 0;" onAction="#goPersonnages"/>
                    <Button text="Œuvre" style="-fx-background-color: transparent; -fx-text-fill: #8b949e; -fx-font-size: 14; -fx-padding: 6 0;" onAction="#goOeuvres"/>
                    <Button text="Artefacts" style="-fx-background-color: transparent; -fx-text-fill: #18E3A4; -fx-font-size: 14; -fx-font-weight: bold; -fx-padding: 6 0; -fx-border-color: #18E3A4; -fx-border-width: 0 0 2 0;" onAction="#goArtefacts"/>
                    <Button text="Boutique" style="-fx-background-color: transparent; -fx-text-fill: #8b949e; -fx-font-size: 14; -fx-padding: 6 0;" onAction="#goShop"/>
                    <Button text="Défis" style="-fx-background-color: transparent; -fx-text-fill: #8b949e; -fx-font-size: 14; -fx-padding: 6 0;" onAction="#goChallenges"/>
                </HBox>
                <Region HBox.hgrow="ALWAYS"/>
                <HBox spacing="15">
                    <Button text="🔍" style="-fx-background-color: transparent; -fx-text-fill: #8b949e; -fx-font-size: 16;"/>
                    <Button text="🛒" style="-fx-background-color: transparent; -fx-text-fill: #8b949e; -fx-font-size: 16;" onAction="#goShop"/>
                    <Button fx:id="profileButton" text="👤" style="-fx-background-color: transparent; -fx-text-fill: #8b949e; -fx-font-size: 16;" onAction="#goProfile"/>
                </HBox>
            </HBox>
        </VBox>
    </top>

    <center>
        <ScrollPane fitToWidth="true" style="-fx-background-color: transparent; -fx-background: transparent;" fitToHeight="true">
            <VBox spacing="30" alignment="TOP_CENTER" style="-fx-padding: 40 60;">

                <VBox spacing="15" alignment="CENTER">
                    <Label text="Tous les Artefacts" style="-fx-text-fill: #ffffff; -fx-font-size: 36; -fx-font-weight: bold;"/>
                    <Label fx:id="resultCount" text="0 artefact(s) trouvé(s)" style="-fx-text-fill: #8b949e; -fx-font-size: 14;"/>
                </VBox>

                <Button fx:id="createBtn" text="+ Créer un Artefact" style="-fx-background-color: #18E3A4; -fx-text-fill: #0a0c10; -fx-font-weight: bold; -fx-padding: 12 24; -fx-background-radius: 30; -fx-font-size: 14;" onAction="#showCreateForm" maxWidth="200"/>

                <HBox spacing="20" alignment="CENTER" style="-fx-background-color: #161b22; -fx-padding: 20; -fx-background-radius: 16;">
                    <VBox spacing="8" HBox.hgrow="ALWAYS">
                        <Label text="Rechercher" style="-fx-text-fill: #8b949e; -fx-font-size: 12; -fx-font-weight: bold;"/>
                        <TextField fx:id="searchField" promptText="Chercher par nom..." style="-fx-background-color: #0d1117; -fx-text-fill: #ffffff; -fx-border-color: #30363d; -fx-border-radius: 8; -fx-padding: 10; -fx-font-size: 14;"/>
                    </VBox>

                    <VBox spacing="8">
                        <Label text="Type" style="-fx-text-fill: #8b949e; -fx-font-size: 12; -fx-font-weight: bold;"/>
                        <ComboBox fx:id="typeFilter" style="-fx-background-color: #0d1117; -fx-text-fill: #ffffff; -fx-border-color: #30363d; -fx-border-radius: 8; -fx-padding: 10; -fx-font-size: 14;" prefWidth="180"/>
                    </VBox>

                    <VBox spacing="8" alignment="BOTTOM_LEFT">
                        <Label text="Filtres" style="-fx-text-fill: #8b949e; -fx-font-size: 12; -fx-font-weight: bold;"/>
                        <HBox spacing="10" alignment="CENTER">
                            <Button fx:id="allBtn" text="Tous" onAction="#showAll" style="-fx-background-color: #18E3A4; -fx-text-fill: #0a0c10; -fx-padding: 8 20; -fx-background-radius: 20; -fx-font-size: 13; -fx-font-weight: bold;"/>
                            <Button fx:id="myItemsBtn" text="Mes artefacts" onAction="#showMyItems" style="-fx-background-color: #21262d; -fx-text-fill: #c9d1d9; -fx-padding: 8 20; -fx-background-radius: 20; -fx-font-size: 13;"/>
                            <Button text="Réinitialiser" style="-fx-background-color: transparent; -fx-text-fill: #8b949e; -fx-border-color: #30363d; -fx-border-width: 1; -fx-padding: 8 20; -fx-background-radius: 20; -fx-font-size: 13;" onAction="#resetFilters"/>
                        </HBox>
                    </VBox>
                </HBox>

                <VBox spacing="20">
                    <HBox spacing="10" alignment="CENTER_LEFT">
                        <Label text="Artefacts" style="-fx-text-fill: #e6edf3; -fx-font-size: 20; -fx-font-weight: bold;"/>
                        <Region HBox.hgrow="ALWAYS"/>
                        <Label fx:id="resultCount2" text="0" style="-fx-text-fill: #18E3A4; -fx-font-weight: bold;"/>
                    </HBox>

                    <FlowPane fx:id="artefactsGrid" hgap="25" vgap="25" alignment="TOP_LEFT" style="-fx-padding: 10 0;"/>

                    <VBox fx:id="emptyState" spacing="20" alignment="CENTER" visible="false" managed="false" style="-fx-padding: 60;">
                        <Label text="✨" style="-fx-text-fill: #8b949e; -fx-font-size: 48;"/>
                        <Label text="Aucun artefact trouvé" style="-fx-text-fill: #8b949e; -fx-font-size: 18;"/>
                        <Button text="Créer le premier artefact" style="-fx-background-color: #18E3A4; -fx-text-fill: #0a0c10; -fx-font-weight: bold; -fx-padding: 10 20; -fx-background-radius: 25;" onAction="#showCreateForm"/>
                    </VBox>
                </VBox>

            </VBox>
        </ScrollPane>
    </center>

    <bottom>
        <VBox style="-fx-background-color: #0d1117; -fx-padding: 30 60;" spacing="20">
            <HBox spacing="50" alignment="CENTER_LEFT">
                <VBox spacing="8">
                    <Label text="MIDGAR" style="-fx-text-fill: #18E3A4; -fx-font-weight: bold; -fx-font-size: 14;"/>
                    <Label text="Plateforme de création fantasy" style="-fx-text-fill: #666; -fx-font-size: 12;"/>
                </VBox>
                <VBox spacing="8">
                    <Label text="À propos" style="-fx-text-fill: #e6edf3; -fx-font-weight: bold; -fx-font-size: 13;"/>
                    <Label text="À propos de Midgar" style="-fx-text-fill: #8b949e; -fx-font-size: 12;"/>
                    <Label text="Notre mission" style="-fx-text-fill: #8b949e; -fx-font-size: 12;"/>
                    <Label text="Équipe" style="-fx-text-fill: #8b949e; -fx-font-size: 12;"/>
                </VBox>
                <VBox spacing="8">
                    <Label text="Légal" style="-fx-text-fill: #e6edf3; -fx-font-weight: bold; -fx-font-size: 13;"/>
                    <Label text="Conditions d'utilisation" style="-fx-text-fill: #8b949e; -fx-font-size: 12;"/>
                    <Label text="Politique de confidentialité" style="-fx-text-fill: #8b949e; -fx-font-size: 12;"/>
                </VBox>
                <VBox spacing="8">
                    <Label text="Contact" style="-fx-text-fill: #e6edf3; -fx-font-weight: bold; -fx-font-size: 13;"/>
                    <Label text="contact@midgar.fr" style="-fx-text-fill: #8b949e; -fx-font-size: 12;"/>
                </VBox>
            </HBox>
            <Label text="© 2026 Midgar Fantasy Platform. Créez, partagez, vivez la magie." style="-fx-text-fill: #666; -fx-font-size: 11;"/>
        </VBox>
    </bottom>

</BorderPane>