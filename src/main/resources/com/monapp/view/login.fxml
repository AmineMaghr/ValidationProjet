<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.image.*?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.text.*?>
<?import javafx.scene.effect.*?>

<AnchorPane xmlns="http://javafx.com/javafx" xmlns:fx="http://javafx.com/fxml" fx:controller="com.midgar.controller.LoginController" style="-fx-background-color: #0d1117;">

    <VBox alignment="CENTER" spacing="0" AnchorPane.leftAnchor="0" AnchorPane.rightAnchor="0" AnchorPane.topAnchor="0" AnchorPane.bottomAnchor="0">
        
        <!-- Header -->
        <HBox alignment="CENTER" style="-fx-background-color: #0b0f10; -fx-padding: 20;">
            <Label text="MIDGAR" style="-fx-text-fill: #18E3A4; -fx-font-size: 28; -fx-font-weight: bold;"/>
        </HBox>

        <!-- Login Card -->
        <VBox style="-fx-background-color: #1a1f1e; -fx-padding: 40; -fx-background-radius: 10;" 
              spacing="20" alignment="CENTER" maxWidth="450">
            <Label text="Connexion" style="-fx-text-fill: #fff; -fx-font-size: 24; -fx-font-weight: bold;"/>
            
            <VBox spacing="15" maxWidth="350">
                <!-- Email Field -->
                <VBox spacing="5">
                    <Label text="Email" style="-fx-text-fill: #b0b9b6;"/>
                    <TextField fx:id="emailField" promptText="votre@email.com" 
                               style="-fx-background-color: #0b0f10; -fx-text-fill: #fff; -fx-border-color: #2a3139; -fx-border-radius: 5; -fx-background-radius: 5; -fx-padding: 10;"/>
                </VBox>
                
                <!-- Password Field -->
                <VBox spacing="5">
                    <Label text="Mot de passe" style="-fx-text-fill: #b0b9b6;"/>
                    <PasswordField fx:id="passwordField" promptText="••••••••" 
                                   style="-fx-background-color: #0b0f10; -fx-text-fill: #fff; -fx-border-color: #2a3139; -fx-border-radius: 5; -fx-background-radius: 5; -fx-padding: 10;"/>
                </VBox>
                
                <!-- Remember & Forgot -->
                <HBox alignment="CENTER_LEFT" spacing="10">
                    <CheckBox text="Se souvenir de moi" style="-fx-text-fill: #b0b9b6;"/>
                    <Region HBox.hgrow="ALWAYS"/>
                    <Button text="Mot de passe oublié?" styleClass="link-button"/>
                </HBox>
            </VBox>

            <!-- Login Button -->
            <Button text="Se connecter" maxWidth="350" style="-fx-background-color: #18E3A4; -fx-text-fill: #0b0f10; -fx-font-weight: bold; -fx-padding: 12 20; -fx-background-radius: 5;"/>

            <!-- Divider -->
            <HBox alignment="CENTER" spacing="10">
                <Line startX="0" endX="100" stroke="#2a3139"/>
                <Label text="OU" style="-fx-text-fill: #666;"/>
                <Line startX="0" endX="100" stroke="#2a3139"/>
            </HBox>

            <!-- Social Login -->
            <HBox spacing="15" alignment="CENTER">
                <Button text="G" style="-fx-background-color: #fff; -fx-background-radius: 5; -fx-padding: 10 20;"/>
                <Button text="F" style="-fx-background-color: #1877f2; -fx-background-radius: 5; -fx-padding: 10 20;"/>
                <Button text="" style="-fx-background-color: #000; -fx-background-radius: 5; -fx-padding: 10 20;"/>
            </HBox>

            <!-- Face Login -->
            <Button text="Connexion par reconnaissance faciale" 
                    style="-fx-background-color: #2a3139; -fx-text-fill: #18E3A4; -fx-padding: 12 20; -fx-background-radius: 5;"/>

            <!-- Register Link -->
            <HBox spacing="5" alignment="CENTER">
                <Label text="Pas encore de compte?" style="-fx-text-fill: #b0b9b6;"/>
                <Button text="S'inscrire" styleClass="link-button"/>
            </HBox>
        </VBox>

    </VBox>

</AnchorPane>