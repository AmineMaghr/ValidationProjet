<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.image.*?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.text.*?>
<?import javafx.scene.shape.Circle?>

<AnchorPane xmlns="http://javafx.com/javafx/17"
            xmlns:fx="http://javafx.com/fxml"
            fx:controller="com.example.app.controllers.RegisterController"
            style="-fx-background-color: #0a0c10;">

    <!-- Header -->
    <VBox style="-fx-background-color: linear-gradient(to right, #0f212e, #0a0c10); -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.5), 10, 0, 0, 2);"
          AnchorPane.leftAnchor="0" AnchorPane.rightAnchor="0" AnchorPane.topAnchor="0">
        <HBox spacing="30" style="-fx-padding: 15 30;" alignment="CENTER_LEFT">
            <HBox spacing="10" alignment="CENTER_LEFT" onMouseClicked="#goToHome" style="-fx-cursor: hand;">
                <Label text="⚡" style="-fx-text-fill: #18E3A4; -fx-font-size: 28px; -fx-font-weight: bold;"/>
                <Label text="MIDGAR" style="-fx-text-fill: #18E3A4; -fx-font-size: 22px; -fx-font-weight: bold;"/>
            </HBox>
            <Region HBox.hgrow="ALWAYS"/>
            <Button text="Se connecter" onAction="#goToLogin"
                    style="-fx-background-color: transparent; -fx-border-color: #18E3A4; -fx-text-fill: #18E3A4; -fx-border-radius: 20; -fx-padding: 8 20; -fx-cursor: hand;"/>
        </HBox>
    </VBox>

    <!-- Contenu principal -->
    <ScrollPane style="-fx-background-color: transparent; -fx-border-color: transparent; -fx-background: transparent;"
                AnchorPane.leftAnchor="0" AnchorPane.rightAnchor="0" AnchorPane.topAnchor="80" AnchorPane.bottomAnchor="0">
        <VBox spacing="30" style="-fx-padding: 30;">

            <!-- Carte d'inscription -->
            <VBox maxWidth="500" style="-fx-background-color: #11161c; -fx-background-radius: 20; -fx-border-color: #1a2530; -fx-border-radius: 20; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.3), 15, 0, 0, 5);">

                <!-- En-tête -->
                <VBox spacing="10" style="-fx-padding: 30 30 20 30; -fx-background-color: #0f212e; -fx-background-radius: 20 20 0 0;">
                    <Label text="📝 Rejoindre Midgar" style="-fx-text-fill: #18E3A4; -fx-font-size: 24px; -fx-font-weight: bold;"/>
                    <Label text="Créez votre compte pour explorer l'univers Midgar" style="-fx-text-fill: #6a7a8a; -fx-font-size: 13px;"/>
                </VBox>

                <Separator style="-fx-background-color: rgba(24,227,164,0.15);"/>

                <!-- Formulaire -->
                <VBox spacing="15" style="-fx-padding: 25 30 25 30;">

                    <!-- Prénom et Nom (2 colonnes) -->
                    <HBox spacing="15">
                        <VBox spacing="5" HBox.hgrow="ALWAYS">
                            <Label text="Prénom" style="-fx-text-fill: #fff; -fx-font-size: 13px; -fx-font-weight: bold;"/>
                            <TextField fx:id="prenomField" promptText="Votre prénom"
                                       style="-fx-background-color: #1a2530; -fx-text-fill: #fff; -fx-prompt-text-fill: #6a7a8a; -fx-background-radius: 10; -fx-padding: 12; -fx-border-color: #2a3540; -fx-border-radius: 10;"/>
                        </VBox>
                        <VBox spacing="5" HBox.hgrow="ALWAYS">
                            <Label text="Nom" style="-fx-text-fill: #fff; -fx-font-size: 13px; -fx-font-weight: bold;"/>
                            <TextField fx:id="nomField" promptText="Votre nom"
                                       style="-fx-background-color: #1a2530; -fx-text-fill: #fff; -fx-prompt-text-fill: #6a7a8a; -fx-background-radius: 10; -fx-padding: 12; -fx-border-color: #2a3540; -fx-border-radius: 10;"/>
                        </VBox>
                    </HBox>

                    <!-- Nom d'utilisateur -->
                    <VBox spacing="5">
                        <Label text="Nom d'utilisateur" style="-fx-text-fill: #fff; -fx-font-size: 13px; -fx-font-weight: bold;"/>
                        <TextField fx:id="usernameField" promptText="3-20 caractères, lettres et chiffres"
                                   style="-fx-background-color: #1a2530; -fx-text-fill: #fff; -fx-prompt-text-fill: #6a7a8a; -fx-background-radius: 10; -fx-padding: 12; -fx-border-color: #2a3540; -fx-border-radius: 10;"/>
                        <Label fx:id="usernameStatus" style="-fx-font-size: 11px;"/>
                    </VBox>

                    <!-- Email -->
                    <VBox spacing="5">
                        <Label text="Email" style="-fx-text-fill: #fff; -fx-font-size: 13px; -fx-font-weight: bold;"/>
                        <TextField fx:id="emailField" promptText="votre.email@exemple.com"
                                   style="-fx-background-color: #1a2530; -fx-text-fill: #fff; -fx-prompt-text-fill: #6a7a8a; -fx-background-radius: 10; -fx-padding: 12; -fx-border-color: #2a3540; -fx-border-radius: 10;"/>
                        <Label fx:id="emailStatus" style="-fx-font-size: 11px;"/>
                    </VBox>

                    <!-- Mot de passe et Confirmation -->
                    <HBox spacing="15">
                        <VBox spacing="5" HBox.hgrow="ALWAYS">
                            <Label text="Mot de passe" style="-fx-text-fill: #fff; -fx-font-size: 13px; -fx-font-weight: bold;"/>
                            <PasswordField fx:id="passwordField" promptText="Minimum 6 caractères"
                                           style="-fx-background-color: #1a2530; -fx-text-fill: #fff; -fx-prompt-text-fill: #6a7a8a; -fx-background-radius: 10; -fx-padding: 12; -fx-border-color: #2a3540; -fx-border-radius: 10;"/>
                            <Label fx:id="passwordStatus" style="-fx-font-size: 11px;"/>
                        </VBox>
                        <VBox spacing="5" HBox.hgrow="ALWAYS">
                            <Label text="Confirmer" style="-fx-text-fill: #fff; -fx-font-size: 13px; -fx-font-weight: bold;"/>
                            <PasswordField fx:id="confirmPasswordField" promptText="Confirmez votre mot de passe"
                                           style="-fx-background-color: #1a2530; -fx-text-fill: #fff; -fx-prompt-text-fill: #6a7a8a; -fx-background-radius: 10; -fx-padding: 12; -fx-border-color: #2a3540; -fx-border-radius: 10;"/>
                            <Label fx:id="confirmStatus" style="-fx-font-size: 11px;"/>
                        </VBox>
                    </HBox>

                    <!-- Photo de profil -->
                    <VBox spacing="5">
                        <Label text="Photo de profil (optionnel)" style="-fx-text-fill: #fff; -fx-font-size: 13px; -fx-font-weight: bold;"/>
                        <HBox spacing="15" alignment="CENTER_LEFT">
                            <Button fx:id="selectPhotoBtn" text="📁 Choisir une photo" onAction="#choosePhoto"
                                    style="-fx-background-color: #2a3540; -fx-text-fill: #fff; -fx-background-radius: 20; -fx-padding: 8 20; -fx-cursor: hand;"/>
                            <ImageView fx:id="photoPreview" fitWidth="50" fitHeight="50" preserveRatio="true"
                                       style="-fx-background-color: #1a2530; -fx-background-radius: 25; -fx-border-color: #18E3A4; -fx-border-radius: 25;"/>
                        </HBox>
                    </VBox>

                    <!-- Message d'erreur -->
                    <Label fx:id="errorLabel" wrapText="true" style="-fx-text-fill: #EF5350; -fx-font-size: 12px; -fx-background-color: rgba(239,83,80,0.1); -fx-padding: 10; -fx-background-radius: 8;" visible="false"/>

                    <!-- Bouton d'inscription -->
                    <Button fx:id="registerBtn" text="✅ Créer mon compte" onAction="#handleRegister"
                            style="-fx-background-color: #18E3A4; -fx-text-fill: #0a0c10; -fx-font-weight: bold; -fx-background-radius: 25; -fx-padding: 14; -fx-font-size: 14px; -fx-cursor: hand; -fx-effect: dropshadow(gaussian, rgba(24,227,164,0.3), 10, 0, 0, 2);"/>

                    <Separator style="-fx-background-color: rgba(24,227,164,0.15);"/>

                    <!-- Lien vers connexion -->
                    <VBox spacing="10" alignment="CENTER">
                        <Label text="Vous avez déjà un compte ?" style="-fx-text-fill: #6a7a8a; -fx-font-size: 12px;"/>
                        <Button text="Se connecter" onAction="#goToLogin"
                                style="-fx-background-color: transparent; -fx-border-color: #6a7a8a; -fx-text-fill: #6a7a8a; -fx-border-radius: 25; -fx-padding: 10; -fx-cursor: hand; -fx-font-weight: bold;"/>
                    </VBox>

                </VBox>

            </VBox>

        </VBox>
    </ScrollPane>

</AnchorPane>