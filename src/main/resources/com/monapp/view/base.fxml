<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.image.*?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.text.*?>

<BorderPane xmlns="http://javafx.com/javafx" xmlns:fx="http://javafx.com/fxml" fx:controller="com.example.app.controllers.BaseController" stylesheets="@../../css/midgar.css">

    <!-- Header / Navigation -->
    <top>
        <VBox style="-fx-background-color: #0b0f10;">
            <!-- Top Bar -->
            <HBox style="-fx-background-color: #071011; -fx-padding: 10 20;" alignment="CENTER_LEFT">
                <Label text="MIDGAR" style="-fx-text-fill: #18E3A4; -fx-font-size: 24; -fx-font-weight: bold;"/>
                <Region HBox.hgrow="ALWAYS"/>
                <HBox spacing="15">
                    <Label text="Français" style="-fx-text-fill: #fff;"/>
                    <Label text="€ EUR" style="-fx-text-fill: #fff;"/>
                </HBox>
            </HBox>
            
            <!-- Main Navigation -->
            <HBox style="-fx-background-color: #0b0f10; -fx-padding: 15 20;" alignment="CENTER">
                <Label text="MIDGAR" style="-fx-text-fill: #18E3A4; -fx-font-size: 20; -fx-font-weight: 800;"/>
                <Region HBox.hgrow="ALWAYS"/>
                <HBox spacing="30">
                    <Button text="ACCUEIL" styleClass="nav-button"/>
                    <Button text="DÉCOUVRIR" styleClass="nav-button"/>
                    <Button text="UNIVERS" styleClass="nav-button"/>
                    <Button text="PERSONNAGES" styleClass="nav-button"/>
                    <Button text="BOUTIQUE" styleClass="nav-button"/>
                    <Button text="DÉFIS" styleClass="nav-button"/>
                </HBox>
                <Region HBox.hgrow="ALWAYS"/>
                <HBox spacing="15">
                    <Button text="🔍" styleClass="icon-button"/>
                    <Button text="🛒" styleClass="icon-button"/>
                    <Button text="👤" styleClass="icon-button"/>
                </HBox>
            </HBox>
        </VBox>
    </top>

    <!-- Main Content Area -->
    <center>
        <StackPane fx:id="contentArea">
            <!-- Content will be loaded here dynamically -->
        </StackPane>
    </center>

    <!-- Footer -->
    <bottom>
        <VBox style="-fx-background-color: #0b0f10; -fx-padding: 40 20;" spacing="20">
            <HBox spacing="40" alignment="CENTER_LEFT">
                <VBox spacing="10">
                    <Label text="MIDGAR" style="-fx-text-fill: #18E3A4; -fx-font-weight: bold;"/>
                    <Label text="Plateforme de création fantasy" style="-fx-text-fill: #888;"/>
                </VBox>
                <VBox spacing="10">
                    <Label text="Liens rapides" style="-fx-text-fill: #fff; -fx-font-weight: bold;"/>
                    <Button text="Accueil" styleClass="footer-link"/>
                    <Button text="Découvrir" styleClass="footer-link"/>
                    <Button text="Univers" styleClass="footer-link"/>
                </VBox>
                <VBox spacing="10">
                    <Label text="Légal" style="-fx-text-fill: #fff; -fx-font-weight: bold;"/>
                    <Button text="CGU" styleClass="footer-link"/>
                    <Button text="Confidentialité" styleClass="footer-link"/>
                </VBox>
                <VBox spacing="10">
                    <Label text="Contact" style="-fx-text-fill: #fff; -fx-font-weight: bold;"/>
                    <Label text="contact@midgar.fr" style="-fx-text-fill: #888;"/>
                </VBox>
            </HBox>
            <Label text="© 2024 Midgar. Tous droits réservés." style="-fx-text-fill: #666;"/>
        </VBox>
    </bottom>

</BorderPane>