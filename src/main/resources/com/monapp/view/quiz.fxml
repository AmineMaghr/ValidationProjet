<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.image.*?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.text.*?>

<AnchorPane xmlns="http://javafx.com/javafx" xmlns:fx="http://javafx.com/fxml" fx:controller="com.example.app.controllers.QuizController" style="-fx-background-color: #0d1117;">

    <fx:include source="partials/header.fxml" AnchorPane.leftAnchor="0" AnchorPane.rightAnchor="0" AnchorPane.topAnchor="0"/>

    <VBox spacing="0" AnchorPane.leftAnchor="0" AnchorPane.rightAnchor="0" AnchorPane.topAnchor="100" AnchorPane.bottomAnchor="0">

        <!-- Quiz Header -->
        <StackPane style="-fx-background-color: linear-gradient(to bottom, #18E3A4, #0d1117); -fx-min-height: 200;">
            <VBox alignment="CENTER" spacing="15">
                <Label text="QUIZ FANTASY" style="-fx-text-fill: #0b0f10; -fx-font-size: 36; -fx-font-weight: bold;"/>
                <Label text="Testez vos connaissances sur l'univers fantasy!" style="-fx-text-fill: #0b0f10;"/>
            </VBox>
        </StackPane>

        <!-- Quiz Content -->
        <VBox style="-fx-padding: 40 100;" spacing="30">
            <HBox alignment="CENTER" spacing="30">
                <VBox spacing="5">
                    <Label text="Question" style="-fx-text-fill: #888;"/>
                    <Label fx:id="questionNumberLabel" text="3/10" style="-fx-text-fill: #fff; -fx-font-size: 20;"/>
                </VBox>
                <VBox spacing="5">
                    <Label text="Score" style="-fx-text-fill: #888;"/>
                    <Label fx:id="scoreLabel" text="150" style="-fx-text-fill: #18E3A4; -fx-font-size: 20;"/>
                </VBox>
                <VBox spacing="5">
                    <Label text="Temps" style="-fx-text-fill: #888;"/>
                    <Label fx:id="timeLabel" text="2:30" style="-fx-text-fill: #fff; -fx-font-size: 20;"/>
                </VBox>
            </HBox>

            <ProgressBar fx:id="progressBar" style="-fx-padding: 5;"/>

            <!-- Question -->
            <VBox style="-fx-background-color: #1a1f1e; -fx-background-radius: 10; -fx-padding: 30;" spacing="25">
                <Label fx:id="questionTextLabel" text="Quelle est la capitale du royaume de Gondor dans Le Seigneur des Anneaux?" style="-fx-text-fill: #fff; -fx-font-size: 18;" wrapText="true"/>

                <VBox fx:id="answersContainer" spacing="15"/>
            </VBox>

            <!-- Navigation -->
            <HBox alignment="CENTER" spacing="20">
                <Button fx:id="previousButton" text="Précédent" onAction="#goToPreviousQuestion" style="-fx-background-color: #2a3139; -fx-text-fill: #fff; -fx-padding: 12 25;"/>
                <Button fx:id="nextButton" text="Suivant" onAction="#goToNextQuestion" style="-fx-background-color: #18E3A4; -fx-text-fill: #0b0f10; -fx-font-weight: bold; -fx-padding: 12 25;"/>
                <Button text="Quitter" onAction="#exitQuiz" style="-fx-background-color: #d64545; -fx-text-fill: white; -fx-padding: 12 25;"/>
            </HBox>
        </VBox>

    </VBox>

</AnchorPane>