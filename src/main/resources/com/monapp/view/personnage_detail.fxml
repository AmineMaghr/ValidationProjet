<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.image.*?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.text.*?>


<AnchorPane xmlns="http://javafx.com/javafx" xmlns:fx="http://javafx.com/fxml" fx:controller="com.midgar.controller.PersonnageDetailController" style="-fx-background-color: #0d1117;">

    <fx:include source="partials/header.fxml" AnchorPane.leftAnchor="0" AnchorPane.rightAnchor="0" AnchorPane.topAnchor="0"/>

    <VBox spacing="0" AnchorPane.leftAnchor="0" AnchorPane.rightAnchor="0" AnchorPane.topAnchor="100">

        <!-- Character Header -->
        <HBox style="-fx-padding: 40 100;" spacing="40">
            <ImageView fitWidth="300" fitHeight="400" style="-fx-background-color: #1a1f1e; -fx-background-radius: 10;"/>
            
            <VBox spacing="15" HBox.hgrow="ALWAYS">
                <Label text="Nom du personnage" style="-fx-text-fill: #fff; -fx-font-size: 32; -fx-font-weight: bold;"/>
                <Label text="Rôle: Héros / Villain / Neutre" style="-fx-text-fill: #18E3A4;"/>
                <Label text="Univers: Nom de l'univers" style="-fx-text-fill: #888;"/>
                
                <VBox spacing="10">
                    <Label text="Description" style="-fx-text-fill: #fff; -fx-font-weight: bold;"/>
                    <Label text="Description du personnage..." style="-fx-text-fill: #b0b9b6;" wrapText="true" maxWidth="500"/>
                </VBox>
                
                <HBox spacing="20">
                    <Button text="Modifier" style="-fx-background-color: #18E3A4; -fx-text-fill: #0b0f10; -fx-font-weight: bold; -fx-padding: 12 20;"/>
                    <Button text="Partager" style="-fx-background-color: #2a3139; -fx-text-fill: #fff; -fx-padding: 12 20;"/>
                </HBox>
            </VBox>
        </HBox>

        <!-- Character Details & Chatbot -->
        <TabPane style="-fx-background-color: #0b0f10;">
            <Tab text="Attributs & Histoire" style="-fx-text-fill: #18E3A4;">
                <VBox style="-fx-background-color: #0b0f10; -fx-padding: 40 100;" spacing="30">
                    <HBox spacing="40">
                        <VBox spacing="15" minWidth="250">
                            <Label text="Attributs" style="-fx-text-fill: #fff; -fx-font-size: 20; -fx-font-weight: bold;"/>
                    <VBox spacing="8">
                        <HBox alignment="CENTER_LEFT">
                            <Label text="Force" style="-fx-text-fill: #888;"/>
                            <Region HBox.hgrow="ALWAYS"/>
                            <Label text="8/10" style="-fx-text-fill: #fff;"/>
                        </HBox>
                        <ProgressBar progress="0.8" style="-fx-pref-width: 200;"/>
                        <HBox alignment="CENTER_LEFT">
                            <Label text="Intelligence" style="-fx-text-fill: #888;"/>
                            <Region HBox.hgrow="ALWAYS"/>
                            <Label text="7/10" style="-fx-text-fill: #fff;"/>
                        </HBox>
                        <ProgressBar progress="0.7" style="-fx-pref-width: 200;"/>
                        <HBox alignment="CENTER_LEFT">
                            <Label text="Agilité" style="-fx-text-fill: #888;"/>
                            <Region HBox.hgrow="ALWAYS"/>
                            <Label text="9/10" style="-fx-text-fill: #fff;"/>
                        </HBox>
                        <ProgressBar progress="0.9" style="-fx-pref-width: 200;"/>
                    </VBox>
                </VBox>
                
                <VBox spacing="15" minWidth="250">
                    <Label text="Histoire" style="-fx-text-fill: #fff; -fx-font-size: 20; -fx-font-weight: bold;"/>
                    <Label text="L'histoire du personnage..." style="-fx-text-fill: #b0b9b6;" wrapText="true" maxWidth="400"/>
                </VBox>
                    </HBox>
                </VBox>
            </Tab>

            <Tab text="🤖 Chat with Character" style="-fx-text-fill: #18E3A4;">
                <fx:include source="ChatbotPanel.fxml"/>
            </Tab>
        </TabPane>

    </VBox>

</AnchorPane>