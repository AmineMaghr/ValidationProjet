<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.image.*?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.text.*?>

<AnchorPane xmlns="http://javafx.com/javafx" xmlns:fx="http://javafx.com/fxml" fx:controller="com.midgar.controller.FaceSetupController" style="-fx-background-color: #0d1117;">

    <VBox alignment="CENTER" spacing="30" AnchorPane.leftAnchor="0" AnchorPane.rightAnchor="0" AnchorPane.topAnchor="0" AnchorPane.bottomAnchor="0">
        
        <!-- Header -->
        <HBox alignment="CENTER" style="-fx-background-color: #0b0f10; -fx-padding: 20;">
            <Label text="MIDGAR" style="-fx-text-fill: #18E3A4; -fx-font-size: 28; -fx-font-weight: bold;"/>
        </HBox>

        <!-- Face Setup Card -->
        <VBox style="-fx-background-color: #1a1f1e; -fx-padding: 40; -fx-background-radius: 10;" 
              spacing="25" alignment="CENTER" maxWidth="500">
            <Label text="Configuration de la reconnaissance faciale" style="-fx-text-fill: #fff; -fx-font-size: 24; -fx-font-weight: bold;" textAlignment="CENTER"/>
            
            <!-- Camera Preview Placeholder -->
            <VBox style="-fx-background-color: #0b0f10; -fx-border-color: #2a3139; -fx-border-width: 2; -fx-border-radius: 10;" 
                  alignment="CENTER" minWidth="300" minHeight="300">
                <Label text="📷" style="-fx-font-size: 80;"/>
                <Label text="Caméra non active" style="-fx-text-fill: #666;"/>
            </VBox>

            <!-- Instructions -->
            <VBox spacing="15" alignment="CENTER">
                <Label text="Instructions:" style="-fx-text-fill: #fff; -fx-font-weight: bold;"/>
                <Label text="1. Placez votre visage au centre du cadre" style="-fx-text-fill: #b0b9b6;"/>
                <Label text="2. Assurez-vous d'être dans un endroit bien éclairé" style="-fx-text-fill: #b0b9b6;"/>
                <Label text="3. Regardez directement la caméra" style="-fx-text-fill: #b0b9b6;"/>
                <Label text="4. Cliquez sur 'Capturer' pour enregistrer votre visage" style="-fx-text-fill: #b0b9b6;"/>
            </VBox>

            <!-- Progress Indicator -->
            <HBox spacing="10" alignment="CENTER">
                <ProgressBar progress="0.0" style="-fx-pref-width: 300;"/>
            </HBox>

            <!-- Action Buttons -->
            <HBox spacing="15" alignment="CENTER">
                <Button text="Capturer" style="-fx-background-color: #18E3A4; -fx-text-fill: #0b0f10; -fx-font-weight: bold; -fx-padding: 12 20; -fx-background-radius: 5;"/>
                <Button text="Recommencer" style="-fx-background-color: #2a3139; -fx-text-fill: #fff; -fx-padding: 12 20; -fx-background-radius: 5;"/>
            </HBox>

            <!-- Skip Link -->
            <HBox spacing="5" alignment="CENTER">
                <Label text="Vous pouvez configurer cela plus tard dans" style="-fx-text-fill: #b0b9b6;"/>
                <Button text="vos paramètres" styleClass="link-button"/>
            </HBox>
        </VBox>

    </VBox>

</AnchorPane>