<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.image.*?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.text.*?>

<AnchorPane xmlns="http://javafx.com/javafx" xmlns:fx="http://javafx.com/fxml" fx:controller="com.example.app.controllers.AdminBaseController" style="-fx-background-color: #0d1117;">

    <HBox spacing="0" AnchorPane.leftAnchor="0" AnchorPane.rightAnchor="0" AnchorPane.topAnchor="0" AnchorPane.bottomAnchor="0">
        
        <!-- Sidebar -->
        <VBox style="-fx-background-color: #0b0f10; -fx-min-width: 250; -fx-padding: 20;" spacing="20">
            <Label text="ADMIN" style="-fx-text-fill: #18E3A4; -fx-font-size: 24; -fx-font-weight: bold;"/>
            
            <VBox spacing="5">
                <Button text="Dashboard" style="-fx-background-color: #18E3A4; -fx-text-fill: #0b0f10; -fx-alignment: CENTER_LEFT; -fx-padding: 12 15;"/>
                <Button text="Utilisateurs" style="-fx-background-color: transparent; -fx-text-fill: #fff; -fx-alignment: CENTER_LEFT; -fx-padding: 12 15;"/>
                <Button text="Univers" style="-fx-background-color: transparent; -fx-text-fill: #fff; -fx-alignment: CENTER_LEFT; -fx-padding: 12 15;"/>
                <Button text="Personnages" style="-fx-background-color: transparent; -fx-text-fill: #fff; -fx-alignment: CENTER_LEFT; -fx-padding: 12 15;"/>
                <Button text="Œuvres" style="-fx-background-color: transparent; -fx-text-fill: #fff; -fx-alignment: CENTER_LEFT; -fx-padding: 12 15;"/>
                <Button text="Produits" style="-fx-background-color: transparent; -fx-text-fill: #fff; -fx-alignment: CENTER_LEFT; -fx-padding: 12 15;"/>
                <Button text="Commandes" style="-fx-background-color: transparent; -fx-text-fill: #fff; -fx-alignment: CENTER_LEFT; -fx-padding: 12 15;"/>
                <Button text="Défis" style="-fx-background-color: transparent; -fx-text-fill: #fff; -fx-alignment: CENTER_LEFT; -fx-padding: 12 15;"/>
            </VBox>
        </VBox>

        <!-- Content Area -->
        <VBox HBox.hgrow="ALWAYS">
            <!-- Top Bar -->
            <HBox style="-fx-background-color: #0b0f10; -fx-padding: 15 20;" alignment="CENTER_RIGHT">
                <Label text="Administrateur" style="-fx-text-fill: #888;"/>
            </HBox>
            
            <!-- Main Content -->
            <StackPane HBox.hgrow="ALWAYS">
                <Label text="Contenu de la page" style="-fx-text-fill: #666;"/>
            </StackPane>
        </VBox>

    </HBox>

</AnchorPane>