<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.image.*?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.text.*?>

<AnchorPane xmlns="http://javafx.com/javafx" xmlns:fx="http://javafx.com/fxml" fx:controller="com.example.app.controllers.AdminController" style="-fx-background-color: #0d1117;">

    <VBox spacing="0" AnchorPane.leftAnchor="250" AnchorPane.rightAnchor="0">
        
        <!-- Header -->
        <HBox style="-fx-background-color: #0b0f10; -fx-padding: 20;" alignment="CENTER_LEFT">
            <Label text="Gestion du Quiz" style="-fx-text-fill: #fff; -fx-font-size: 24; -fx-font-weight: bold;"/>
            <Region HBox.hgrow="ALWAYS"/>
            <Button text="+ Nouvelle question" style="-fx-background-color: #18E3A4; -fx-text-fill: #0b0f10; -fx-padding: 10 20; -fx-background-radius: 5;"/>
        </HBox>

        <!-- Quiz Questions -->
        <VBox style="-fx-padding: 20;" spacing="15">
            <VBox style="-fx-background-color: #1a1f1e; -fx-background-radius: 10; -fx-padding: 20;" spacing="15">
                <HBox alignment="CENTER_LEFT">
                    <Label text="Question 1" style="-fx-text-fill: #fff; -fx-font-weight: bold;"/>
                    <Region HBox.hgrow="ALWAYS"/>
                    <Button text="Modifier" style="-fx-background-color: #2a3139; -fx-text-fill: #fff; -fx-padding: 5 10;"/>
                    <Button text="Supprimer" style="-fx-background-color: #ff6b6b; -fx-text-fill: #fff; -fx-padding: 5 10;"/>
                </HBox>
                <Label text="Quelle est la capitale de la France?" style="-fx-text-fill: #888;"/>
                <VBox spacing="5">
                    <Label text="A) London" style="-fx-text-fill: #666;"/>
                    <Label text="B) Paris ✓" style="-fx-text-fill: #18E3A4;"/>
                    <Label text="C) Berlin" style="-fx-text-fill: #666;"/>
                    <Label text="D) Madrid" style="-fx-text-fill: #666;"/>
                </VBox>
            </VBox>
            
            <VBox style="-fx-background-color: #1a1f1e; -fx-background-radius: 10; -fx-padding: 20;" spacing="15">
                <HBox alignment="CENTER_LEFT">
                    <Label text="Question 2" style="-fx-text-fill: #fff; -fx-font-weight: bold;"/>
                    <Region HBox.hgrow="ALWAYS"/>
                    <Button text="Modifier" style="-fx-background-color: #2a3139; -fx-text-fill: #fff; -fx-padding: 5 10;"/>
                    <Button text="Supprimer" style="-fx-background-color: #ff6b6b; -fx-text-fill: #fff; -fx-padding: 5 10;"/>
                </HBox>
                <Label text="Qui a écrit Hamlet?" style="-fx-text-fill: #888;"/>
                <VBox spacing="5">
                    <Label text="A) Charles Dickens" style="-fx-text-fill: #666;"/>
                    <Label text="B) William Shakespeare ✓" style="-fx-text-fill: #18E3A4;"/>
                    <Label text="C) Victor Hugo" style="-fx-text-fill: #666;"/>
                    <Label text="D) Molière" style="-fx-text-fill: #666;"/>
                </VBox>
            </VBox>
        </VBox>

    </VBox>

</AnchorPane>