<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.image.*?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.text.*?>

<AnchorPane xmlns="http://javafx.com/javafx" xmlns:fx="http://javafx.com/fxml" fx:controller="com.example.app.controllers.AdminController" style="-fx-background-color: #0d1117;">

    <VBox spacing="0" AnchorPane.leftAnchor="250" AnchorPane.rightAnchor="0" AnchorPane.topAnchor="0">
        
        <!-- Header -->
        <HBox style="-fx-background-color: #0b0f10; -fx-padding: 20;" alignment="CENTER_LEFT">
            <Label text="Gestion des utilisateurs" style="-fx-text-fill: #fff; -fx-font-size: 24; -fx-font-weight: bold;"/>
            <Region HBox.hgrow="ALWAYS"/>
            <Button text="+ Ajouter un utilisateur" style="-fx-background-color: #18E3A4; -fx-text-fill: #0b0f10; -fx-padding: 10 20; -fx-background-radius: 5;"/>
        </HBox>

        <!-- Filters -->
        <HBox style="-fx-padding: 20;" spacing="15">
            <TextField promptText="Rechercher..." style="-fx-background-color: #1a1f1e; -fx-text-fill: #fff; -fx-border-color: #2a3139; -fx-background-radius: 5; -fx-pref-width: 300;"/>
            <ComboBox promptText="Rôle" style="-fx-background-color: #1a1f1e; -fx-text-fill: #fff;"/>
            <Button text="Filtrer" style="-fx-background-color: #2a3139; -fx-text-fill: #fff; -fx-padding: 8 15;"/>
        </HBox>

        <!-- Users Table -->
        <VBox style="-fx-padding: 0 20 20 20;" spacing="15">
            <TableView style="-fx-background-color: #1a1f1e;">
                <columns>
                    <TableColumn text="ID" prefWidth="50"/>
                    <TableColumn text="Pseudo" prefWidth="150"/>
                    <TableColumn text="Email" prefWidth="200"/>
                    <TableColumn text="Rôle" prefWidth="100"/>
                    <TableColumn text="Date d'inscription" prefWidth="150"/>
                    <TableColumn text="Actions" prefWidth="150"/>
                </columns>
            </TableView>
            
            <!-- Pagination -->
            <HBox alignment="CENTER" spacing="10">
                <Button text="◀" style="-fx-background-color: #2a3139; -fx-text-fill: #fff;"/>
                <Label text="Page 1 sur 10" style="-fx-text-fill: #888;"/>
                <Button text="▶" style="-fx-background-color: #2a3139; -fx-text-fill: #fff;"/>
            </HBox>
        </VBox>

    </VBox>

</AnchorPane>