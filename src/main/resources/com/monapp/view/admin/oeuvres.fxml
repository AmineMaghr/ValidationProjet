<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.image.*?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.text.*?>

<AnchorPane xmlns="http://javafx.com/javafx" xmlns:fx="http://javafx.com/fxml" fx:controller="com.example.app.controllers.AdminController" style="-fx-background-color: #0d1117;">

    <VBox spacing="0" AnchorPane.leftAnchor="250" AnchorPane.rightAnchor="0">
        
        <HBox style="-fx-background-color: #0b0f10; -fx-padding: 20;" alignment="CENTER_LEFT">
            <Label text="Gestion des œuvres" style="-fx-text-fill: #fff; -fx-font-size: 24; -fx-font-weight: bold;"/>
        </HBox>

        <VBox style="-fx-padding: 20;" spacing="20">
            <HBox spacing="20">
                <VBox style="-fx-background-color: #1a1f1e; -fx-background-radius: 10; -fx-min-width: 250;" spacing="10">
                    <ImageView fitWidth="250" fitHeight="180" style="-fx-background-radius: 10 10 0 0;"/>
                    <VBox style="-fx-padding: 15;">
                        <Label text="Titre de l'œuvre" style="-fx-text-fill: #fff; -fx-font-weight: bold;"/>
                        <Label text="Type: Illustration" style="-fx-text-fill: #888;"/>
                        <HBox spacing="10">
                            <Button text="Voir" style="-fx-background-color: #2a3139; -fx-text-fill: #fff;"/>
                            <Button text="Supprimer" style="-fx-background-color: #ff6b6b; -fx-text-fill: #fff;"/>
                        </HBox>
                    </VBox>
                </VBox>
            </HBox>
        </VBox>

    </VBox>

</AnchorPane>