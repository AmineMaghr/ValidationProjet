<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.text.*?>

<AnchorPane xmlns="http://javafx.com/javafx/17"
            xmlns:fx="http://javafx.com/fxml"
            fx:controller="com.example.app.controllers.AdminController"
            style="-fx-background-color: #0a0c10;">

    <!-- Sidebar -->
    <VBox style="-fx-background-color: #0d1117; -fx-border-color: #1a2530; -fx-border-width: 0 1 0 0;"
          AnchorPane.leftAnchor="0" AnchorPane.topAnchor="0" AnchorPane.bottomAnchor="0" prefWidth="260" spacing="0">
        
        <VBox spacing="15" style="-fx-padding: 30 20 20 20;">
            <Label text="⚡" style="-fx-text-fill: #18E3A4; -fx-font-size: 36px;"/>
            <Label text="MIDGAR ADMIN" style="-fx-text-fill: #18E3A4; -fx-font-size: 18px; -fx-font-weight: bold; -fx-letter-spacing: 2px;"/>
            <Separator style="-fx-background-color: rgba(24,227,164,0.2);"/>
        </VBox>
        
        <VBox spacing="8" style="-fx-padding: 10 20 0 20;">
            <Button text="🏠 Dashboard" style="-fx-background-color: transparent; -fx-text-fill: #b0b9b6; -fx-padding: 12 15; -fx-alignment: CENTER_LEFT; -fx-background-radius: 10; -fx-cursor: hand;" 
                    onAction="#goHome" onMouseEntered="#onButtonHover" onMouseExited="#onButtonExit"/>
            <Button text="👥 Utilisateurs" style="-fx-background-color: transparent; -fx-text-fill: #b0b9b6; -fx-padding: 12 15; -fx-alignment: CENTER_LEFT; -fx-background-radius: 10; -fx-cursor: hand;" 
                    onAction="#showUsersTab" onMouseEntered="#onButtonHover" onMouseExited="#onButtonExit"/>
            <Button text="📚 Œuvres" style="-fx-background-color: #18E3A4; -fx-text-fill: #0a0c10; -fx-padding: 12 15; -fx-alignment: CENTER_LEFT; -fx-background-radius: 10; -fx-font-weight: bold; -fx-cursor: hand;" 
                    onAction="#showOeuvresTab"/>
            <Button text="⚡ Artefacts" style="-fx-background-color: transparent; -fx-text-fill: #b0b9b6; -fx-padding: 12 15; -fx-alignment: CENTER_LEFT; -fx-background-radius: 10; -fx-cursor: hand;" 
                    onAction="#showArtefactsTab" onMouseEntered="#onButtonHover" onMouseExited="#onButtonExit"/>
        </VBox>
        
        <Region VBox.vgrow="ALWAYS"/>
        
        <VBox spacing="15" style="-fx-padding: 20;">
            <Separator style="-fx-background-color: rgba(24,227,164,0.15);"/>
            <Button text="← Retour au profil" onAction="#returnToProfile"
                    style="-fx-background-color: transparent; -fx-border-color: #18E3A4; -fx-text-fill: #18E3A4; -fx-border-radius: 25; -fx-padding: 12; -fx-cursor: hand; -fx-font-weight: bold;"
                    onMouseEntered="#onButtonHover" onMouseExited="#onButtonExit"/>
        </VBox>
    </VBox>

    <!-- Contenu principal -->
    <VBox spacing="0" AnchorPane.leftAnchor="260" AnchorPane.rightAnchor="0" AnchorPane.topAnchor="0" AnchorPane.bottomAnchor="0">
        
        <!-- Header -->
        <VBox style="-fx-background-color: #0b0f10; -fx-border-color: #1a2530; -fx-border-width: 0 0 1 0;">
            <HBox style="-fx-padding: 20 30;" alignment="CENTER_LEFT">
                <VBox>
                    <Label text="Gestion des œuvres" style="-fx-text-fill: #fff; -fx-font-size: 22px; -fx-font-weight: bold;"/>
                    <Label text="Gérez toutes les œuvres de la plateforme" style="-fx-text-fill: #6a7a8a; -fx-font-size: 12px;"/>
                </VBox>
                <Region HBox.hgrow="ALWAYS"/>
                <Button text="🏠 Retour au site" onAction="#goHome"
                        style="-fx-background-color: #1a2530; -fx-text-fill: #18E3A4; -fx-padding: 10 20; -fx-background-radius: 25; -fx-cursor: hand; -fx-border-color: #18E3A4; -fx-border-radius: 25;"
                        onMouseEntered="#onButtonHover" onMouseExited="#onButtonExit"/>
            </HBox>
            
            <!-- Cartes statistiques -->
            <HBox spacing="20" style="-fx-padding: 0 30 25 30;">
                <VBox spacing="8" style="-fx-padding: 20; -fx-background-color: #0f212e; -fx-background-radius: 15; -fx-border-color: #1a2530; -fx-border-radius: 15; -fx-min-width: 160;">
                    <Label text="📚" style="-fx-font-size: 32px;"/>
                    <Label text="Total Œuvres" style="-fx-text-fill: #6a7a8a; -fx-font-size: 11px; -fx-font-weight: bold;"/>
                    <Label fx:id="totalOeuvresLabel" text="0" style="-fx-text-fill: #18E3A4; -fx-font-size: 32px; -fx-font-weight: bold;"/>
                </VBox>
                
                <VBox spacing="8" style="-fx-padding: 20; -fx-background-color: #0f212e; -fx-background-radius: 15; -fx-border-color: #1a2530; -fx-border-radius: 15; -fx-min-width: 160;">
                    <Label text="✍️" style="-fx-font-size: 32px;"/>
                    <Label text="Auteurs" style="-fx-text-fill: #6a7a8a; -fx-font-size: 11px; -fx-font-weight: bold;"/>
                    <Label fx:id="totalAuteursLabel" text="0" style="-fx-text-fill: #FFA726; -fx-font-size: 32px; -fx-font-weight: bold;"/>
                </VBox>
                
                <VBox spacing="8" style="-fx-padding: 20; -fx-background-color: #0f212e; -fx-background-radius: 15; -fx-border-color: #1a2530; -fx-border-radius: 15; -fx-min-width: 160;">
                    <Label text="📊" style="-fx-font-size: 32px;"/>
                    <Label text="Taux de publication" style="-fx-text-fill: #6a7a8a; -fx-font-size: 11px; -fx-font-weight: bold;"/>
                    <Label text="75%" style="-fx-text-fill: #18E3A4; -fx-font-size: 32px; -fx-font-weight: bold;"/>
                </VBox>
            </HBox>
        </VBox>

        <!-- Barre de recherche -->
        <HBox style="-fx-padding: 25 30 15 30;" spacing="15" alignment="CENTER_LEFT">
            <HBox spacing="10" style="-fx-background-color: #1a2530; -fx-background-radius: 25; -fx-padding: 5 15;" HBox.hgrow="ALWAYS">
                <Label text="🔍" style="-fx-text-fill: #6a7a8a;"/>
                <TextField fx:id="searchOeuvreField" promptText="Rechercher par titre ou auteur..."
                           style="-fx-background-color: transparent; -fx-text-fill: #fff; -fx-prompt-text-fill: #6a7a8a;"/>
            </HBox>
            <Button text="Rechercher" onAction="#searchOeuvres"
                    style="-fx-background-color: #18E3A4; -fx-text-fill: #0a0c10; -fx-font-weight: bold; -fx-padding: 8 25; -fx-background-radius: 25; -fx-cursor: hand;"
                    onMouseEntered="#onButtonHover" onMouseExited="#onButtonExit"/>
            <Button text="Réinitialiser" onAction="#resetOeuvreFilters"
                    style="-fx-background-color: #2a3540; -fx-text-fill: #fff; -fx-padding: 8 25; -fx-background-radius: 25; -fx-cursor: hand;"
                    onMouseEntered="#onButtonHover" onMouseExited="#onButtonExit"/>
        </HBox>

        <!-- Table Œuvres -->
        <VBox spacing="15" style="-fx-padding: 0 30 30 30;" VBox.vgrow="ALWAYS">
            <TableView fx:id="oeuvreTable" style="-fx-background-color: #11161c; -fx-background-radius: 12; -fx-border-color: #1a2530; -fx-border-radius: 12;" VBox.vgrow="ALWAYS">
                <columns>
                    <TableColumn text="ID" prefWidth="60" style="-fx-alignment: CENTER;"/>
                    <TableColumn text="Titre" prefWidth="250"/>
                    <TableColumn text="Type" prefWidth="120" style="-fx-alignment: CENTER;"/>
                    <TableColumn text="Auteur" prefWidth="180"/>
                    <TableColumn text="Date" prefWidth="120" style="-fx-alignment: CENTER;"/>
                    <TableColumn text="Actions" prefWidth="120" style="-fx-alignment: CENTER;"/>
                </columns>
                <style>
                    .table-view .column-header .label {
                        -fx-text-fill: #18E3A4;
                        -fx-font-weight: bold;
                    }
                </style>
            </TableView>
        </VBox>

    </VBox>
</AnchorPane>