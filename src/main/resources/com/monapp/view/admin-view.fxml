<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.text.*?>

<AnchorPane xmlns="http://javafx.com/javafx/17"
            xmlns:fx="http://javafx.com/fxml"
            fx:controller="com.example.app.controllers.AdminController"
            style="-fx-background-color: #0a0c10;">

    <!-- Header -->
    <HBox style="-fx-background-color: #1a1d23; -fx-padding: 10;" AnchorPane.leftAnchor="0" AnchorPane.rightAnchor="0" AnchorPane.topAnchor="0">
        <Label text="Administration - Midgar" style="-fx-text-fill: #18E3A4; -fx-font-size: 18px; -fx-font-weight: bold;"/>
        <Region HBox.hgrow="ALWAYS"/>
        <Button text="Retour à l'accueil" onAction="#goHome" styleClass="btn-secondary"/>
    </HBox>

    <!-- Main Content -->
    <TabPane fx:id="adminTabPane" AnchorPane.leftAnchor="0" AnchorPane.rightAnchor="0" AnchorPane.topAnchor="60" AnchorPane.bottomAnchor="0">

        <!-- Users Tab -->
        <Tab text="Utilisateurs" closable="false">
            <VBox spacing="10" style="-fx-padding: 20;">
                <HBox spacing="10" alignment="CENTER_LEFT">
                    <TextField fx:id="searchField" promptText="Rechercher un utilisateur..." HBox.hgrow="ALWAYS"/>
                    <Button text="Rechercher" onAction="#searchUsers" styleClass="btn-primary"/>
                    <Button text="Bloquer/Suspendre" onAction="#toggleUserStatus" styleClass="btn-danger"/>
                    <Button text="Supprimer" onAction="#deleteUser" styleClass="btn-danger"/>
                </HBox>
                <TableView fx:id="userTable" VBox.vgrow="ALWAYS">
                    <columns>
                        <TableColumn fx:id="colId" text="ID" prefWidth="50"/>
                        <TableColumn fx:id="colUsername" text="Nom d'utilisateur" prefWidth="120"/>
                        <TableColumn fx:id="colLastName" text="Nom" prefWidth="100"/>
                        <TableColumn fx:id="colFirstName" text="Prénom" prefWidth="100"/>
                        <TableColumn fx:id="colEmail" text="Email" prefWidth="150"/>
                        <TableColumn fx:id="colRole" text="Rôle" prefWidth="80"/>
                        <TableColumn fx:id="colCreatedAt" text="Créé le" prefWidth="120"/>
                        <TableColumn fx:id="colBlocked" text="Bloqué" prefWidth="80"/>
                    </columns>
                </TableView>
            </VBox>
        </Tab>

        <!-- Oeuvres Tab -->
        <Tab text="Œuvres" closable="false">
            <VBox spacing="10" style="-fx-padding: 20;">
                <HBox spacing="10" alignment="CENTER_LEFT">
                    <TextField promptText="Rechercher une œuvre..." HBox.hgrow="ALWAYS"/>
                    <Button text="Rechercher" onAction="#searchOeuvres" styleClass="btn-primary"/>
                    <Button text="Modifier" onAction="#editOeuvre" styleClass="btn-secondary"/>
                    <Button text="Supprimer" onAction="#deleteOeuvre" styleClass="btn-danger"/>
                </HBox>
                <TableView fx:id="oeuvreTable" VBox.vgrow="ALWAYS">
                    <columns>
                        <TableColumn text="ID" prefWidth="50"/>
                        <TableColumn text="Titre" prefWidth="150"/>
                        <TableColumn text="Auteur" prefWidth="120"/>
                        <TableColumn text="Catégorie" prefWidth="100"/>
                    </columns>
                </TableView>
            </VBox>
        </Tab>

        <!-- Artefacts Tab -->
        <Tab text="Artefacts" closable="false">
            <VBox spacing="10" style="-fx-padding: 20;">
                <HBox spacing="10" alignment="CENTER_LEFT">
                    <TextField promptText="Rechercher un artefact..." HBox.hgrow="ALWAYS"/>
                    <Button text="Rechercher" onAction="#searchArtefacts" styleClass="btn-primary"/>
                    <Button text="Modifier" onAction="#editArtefact" styleClass="btn-secondary"/>
                    <Button text="Supprimer" onAction="#deleteArtefact" styleClass="btn-danger"/>
                </HBox>
                <TableView fx:id="artefactTable" VBox.vgrow="ALWAYS">
                    <columns>
                        <TableColumn text="ID" prefWidth="50"/>
                        <TableColumn text="Nom" prefWidth="150"/>
                        <TableColumn text="Type" prefWidth="120"/>
                        <TableColumn text="Univers" prefWidth="100"/>
                        <TableColumn text="Créé le" prefWidth="120"/>
                    </columns>
                </TableView>
            </VBox>
        </Tab>

    </TabPane>

</AnchorPane>