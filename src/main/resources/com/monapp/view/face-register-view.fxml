<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.image.ImageView?>

<AnchorPane xmlns="http://javafx.com/javafx/17"
            xmlns:fx="http://javafx.com/fxml"
            fx:controller="com.example.app.controllers.FaceRegisterController"
            style="-fx-background-color: #0a0c10;">

    <VBox alignment="CENTER" spacing="15"
          AnchorPane.topAnchor="0"
          AnchorPane.bottomAnchor="0"
          AnchorPane.leftAnchor="0"
          AnchorPane.rightAnchor="0">

        <Label text="ENREGISTREMENT FACIAL"
               style="-fx-text-fill: #18E3A4;
                      -fx-font-size: 22px;
                      -fx-font-weight: bold;"/>

        <!-- VIDEO AU LIEU DE CAMERA -->
        <StackPane prefWidth="640" prefHeight="480"
                   style="-fx-background-color: #000;
                          -fx-background-radius: 15;
                          -fx-border-color: #18E3A4;
                          -fx-border-width: 2;">

            <ImageView fx:id="cameraPreview"
                       fitWidth="640"
                       fitHeight="480"
                       preserveRatio="true"/>
        </StackPane>

        <Label fx:id="statusLabel"
               text="Initialisation..."
               style="-fx-text-fill: white;"/>

        <HBox spacing="15" alignment="CENTER">

            <Button text="🎥 Démarrer"
                    onAction="#startCamera"/>

            <Button fx:id="captureBtn"
                    text="📸 Capturer"
                    onAction="#capture"
                    disable="true"/>

            <Button fx:id="saveBtn"
                    text="💾 Enregistrer"
                    onAction="#save"
                    disable="true"/>

        </HBox>

    </VBox>

</AnchorPane>