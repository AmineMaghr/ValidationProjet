<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.image.*?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.text.*?>
<?import javafx.scene.shape.Circle?>

<AnchorPane xmlns="http://javafx.com/javafx/17" 
            xmlns:fx="http://javafx.com/fxml" 
            fx:controller="com.example.app.controllers.ProfileController"
            style="-fx-background-color: #0a0c10;">

    <!-- Header -->
    <VBox style="-fx-background-color: linear-gradient(to right, #0f212e, #0a0c10);"
          AnchorPane.leftAnchor="0" AnchorPane.rightAnchor="0" AnchorPane.topAnchor="0">
        <HBox spacing="30" style="-fx-padding: 15 30;" alignment="CENTER_LEFT">
            <HBox spacing="10" alignment="CENTER_LEFT" onMouseClicked="#goToHome" style="-fx-cursor: hand;">
                <Label text="MIDGAR" style="-fx-text-fill: #18E3A4; -fx-font-size: 22px; -fx-font-weight: bold;"/>
            </HBox>
            <Region HBox.hgrow="ALWAYS"/>
            <Button text="Accueil" onAction="#goToHome"
                    style="-fx-background-color: transparent; -fx-text-fill: #b0b9b6; -fx-cursor: hand;"/>
        </HBox>
    </VBox>

    <!-- Contenu principal -->
    <ScrollPane style="-fx-background-color: transparent; -fx-border-color: transparent;"
                AnchorPane.leftAnchor="0" AnchorPane.rightAnchor="0" AnchorPane.topAnchor="80" AnchorPane.bottomAnchor="0">
        <VBox spacing="25" style="-fx-padding: 25 30;">
            
            <!-- Bannière de profil -->
            <VBox spacing="20" style="-fx-padding: 30; -fx-background-color: #0f212e; -fx-background-radius: 15; -fx-border-color: rgba(24,227,164,0.2); -fx-border-radius: 15;">
                <HBox spacing="20" alignment="CENTER_LEFT">
                    <!-- Avatar -->
                    <VBox spacing="5" alignment="CENTER">
                        <ImageView fx:id="avatarImage" fitWidth="120" fitHeight="120" preserveRatio="true"
                                   style="-fx-background-color: #1a2530; -fx-background-radius: 60; -fx-border-color: #18E3A4; -fx-border-radius: 60; -fx-border-width: 4; -fx-effect: dropshadow(gaussian, rgba(24,227,164,0.4), 15, 0, 0, 3);"/>
                        <Label text="👤 Photo de profil" style="-fx-text-fill: #6a7a8a; -fx-font-size: 10px;"/>
                    </VBox>

                    <!-- Infos utilisateur -->
                    <VBox spacing="8">
                        <HBox spacing="10" alignment="CENTER_LEFT">
                            <Label fx:id="usernameLabel" style="-fx-text-fill: #18E3A4; -fx-font-size: 26px; -fx-font-weight: bold;"/>
                            <Label text="✓" style="-fx-text-fill: #18E3A4; -fx-font-size: 16px;"/>
                        </HBox>
                        <Label fx:id="fullNameLabel" style="-fx-text-fill: #b0b9b6; -fx-font-size: 15px;"/>
                        <Label fx:id="emailLabel" style="-fx-text-fill: #b0b9b6; -fx-font-size: 14px;"/>
                        <Label fx:id="memberSinceLabel" style="-fx-text-fill: #6a7a8a; -fx-font-size: 13px;"/>
                    </VBox>
                    
                    <Region HBox.hgrow="ALWAYS"/>
                    
                    <!-- Boutons d'action -->
                    <VBox spacing="10">
                        <Button text="✏️ Editer le profil" onAction="#handleEditProfile"
                                style="-fx-background-color: #18E3A4; -fx-text-fill: #0a0c10; -fx-font-weight: bold; -fx-background-radius: 25; -fx-padding: 10 20; -fx-cursor: hand; -fx-effect: dropshadow(gaussian, rgba(24,227,164,0.3), 10, 0, 0, 2);"/>
                        <Button text="🔒 Changer mot de passe" onAction="#handleChangePassword"
                                style="-fx-background-color: #2a3540; -fx-text-fill: #fff; -fx-background-radius: 25; -fx-padding: 10 20; -fx-cursor: hand; -fx-effect: dropshadow(gaussian, rgba(42,53,64,0.3), 10, 0, 0, 2);"/>
                        <Button fx:id="adminBtn" text="👑 Administration" onAction="#goToAdmin" visible="false"
                                style="-fx-background-color: #FFA726; -fx-text-fill: #0a0c10; -fx-font-weight: bold; -fx-background-radius: 25; -fx-padding: 10 20; -fx-cursor: hand; -fx-effect: dropshadow(gaussian, rgba(255,167,38,0.3), 10, 0, 0, 2);"/>
                        <Button text="🚪 Deconnexion" onAction="#handleLogout"
                                style="-fx-background-color: transparent; -fx-border-color: #EF5350; -fx-text-fill: #EF5350; -fx-border-radius: 25; -fx-padding: 10 20; -fx-cursor: hand; -fx-effect: dropshadow(gaussian, rgba(239,83,80,0.3), 10, 0, 0, 2);"/>
                    </VBox>
                </HBox>
            </VBox>
            
            <!-- Statistiques -->
            <HBox spacing="20">
                <VBox spacing="5" style="-fx-padding: 20; -fx-background-color: #11161c; -fx-background-radius: 12; -fx-border-color: #1a2530; -fx-border-radius: 12; -fx-alignment: CENTER; -fx-min-width: 150;">
                    <Label text="Oeuvres" style="-fx-text-fill: #b0b9b6; -fx-font-size: 16px; -fx-font-weight: bold;"/>
                    <Label fx:id="oeuvresCountLabel" text="0" style="-fx-text-fill: #18E3A4; -fx-font-size: 28px; -fx-font-weight: bold;"/>
                </VBox>
                <VBox spacing="5" style="-fx-padding: 20; -fx-background-color: #11161c; -fx-background-radius: 12; -fx-border-color: #1a2530; -fx-border-radius: 12; -fx-alignment: CENTER; -fx-min-width: 150;">
                    <Label text="Artefacts" style="-fx-text-fill: #b0b9b6; -fx-font-size: 16px; -fx-font-weight: bold;"/>
                    <Label fx:id="artefactsCountLabel" text="0" style="-fx-text-fill: #18E3A4; -fx-font-size: 28px; -fx-font-weight: bold;"/>
                </VBox>
                <VBox spacing="5" style="-fx-padding: 20; -fx-background-color: #11161c; -fx-background-radius: 12; -fx-border-color: #1a2530; -fx-border-radius: 12; -fx-alignment: CENTER; -fx-min-width: 150;">
                    <Label text="Favoris" style="-fx-text-fill: #b0b9b6; -fx-font-size: 16px; -fx-font-weight: bold;"/>
                    <Label fx:id="favoritesCountLabel" text="0" style="-fx-text-fill: #18E3A4; -fx-font-size: 28px; -fx-font-weight: bold;"/>
                </VBox>
            </HBox>
            
            <!-- Onglets pour les créations -->
            <TabPane fx:id="contentTabPane" style="-fx-background-color: transparent; -fx-tab-min-height: 40;">
                <Tab text="Mes Oeuvres" closable="false">
                    <VBox spacing="15" style="-fx-padding: 20;">
                        <TilePane fx:id="oeuvresGrid" prefColumns="3" hgap="20" vgap="20" style="-fx-background-color: transparent;"/>
                    </VBox>
                </Tab>
                <Tab text="Mes Artefacts" closable="false">
                    <VBox spacing="15" style="-fx-padding: 20;">
                        <TilePane fx:id="artefactsGrid" prefColumns="3" hgap="20" vgap="20" style="-fx-background-color: transparent;"/>
                    </VBox>
                </Tab>
                <Tab text="Mes Favoris" closable="false">
                    <VBox spacing="15" style="-fx-padding: 20;">
                        <Label text="Favoris - Œuvres" style="-fx-text-fill: #18E3A4; -fx-font-size: 18px; -fx-font-weight: bold;"/>
                        <TilePane fx:id="favoriteOeuvresGrid" prefColumns="3" hgap="20" vgap="20" style="-fx-background-color: transparent;"/>
                        <Label text="Favoris - Artefacts" style="-fx-text-fill: #18E3A4; -fx-font-size: 18px; -fx-font-weight: bold; -fx-padding: 20 0 0 0;"/>
                        <TilePane fx:id="favoriteArtefactsGrid" prefColumns="3" hgap="20" vgap="20" style="-fx-background-color: transparent;"/>
                    </VBox>
                </Tab>
            </TabPane>
            
        </VBox>
    </ScrollPane>
    
</AnchorPane>