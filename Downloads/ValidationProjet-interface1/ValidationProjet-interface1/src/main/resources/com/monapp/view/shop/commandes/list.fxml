<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.image.*?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.text.*?>

<AnchorPane xmlns="http://javafx.com/javafx" xmlns:fx="http://javafx.com/fxml" fx:controller="com.midgar.controller.ShopCommandesController" style="-fx-background-color: #0d1117;">

    <VBox spacing="0" AnchorPane.leftAnchor="0" AnchorPane.rightAnchor="0">
        
        <StackPane style="-fx-background-color: #0b0f10; -fx-min-height: 150;">
            <VBox alignment="CENTER">
                <Label text="MES COMMANDES" style="-fx-text-fill: #fff; -fx-font-size: 36; -fx-font-weight: bold;"/>
            </VBox>
        </StackPane>

        <VBox style="-fx-padding: 30 100;" spacing="20">
            <VBox style="-fx-background-color: #1a1f1e; -fx-background-radius: 10; -fx-padding: 20;" spacing="15">
                <HBox alignment="CENTER_LEFT">
                    <Label text="Commande #1234" style="-fx-text-fill: #fff; -fx-font-weight: bold;"/>
                    <Region HBox.hgrow="ALWAYS"/>
                    <Label text="Livrée" style="-fx-text-fill: #18E3A4;"/>
                </HBox>
                <Label text="Date: 15/04/2024 - Montant: 45.00€" style="-fx-text-fill: #888;"/>
                <Button text="Voir détails" style="-fx-background-color: #2a3139; -fx-text-fill: #fff;"/>
            </VBox>
        </VBox>

    </VBox>

</AnchorPane>