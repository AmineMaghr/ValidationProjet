<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.image.*?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.text.*?>

<AnchorPane xmlns="http://javafx.com/javafx" xmlns:fx="http://javafx.com/fxml" fx:controller="com.example.app.controllers.ArtefactController" style="-fx-background-color: #0d1117;">

    <VBox spacing="0" AnchorPane.leftAnchor="0" AnchorPane.rightAnchor="0">
        
        <StackPane style="-fx-background-color: linear-gradient(to bottom, #1a1f1e, #0d1117); -fx-min-height: 200;">
            <VBox alignment="CENTER">
                <Label text="ARTEFACTS" style="-fx-text-fill: #fff; -fx-font-size: 36; -fx-font-weight: bold;"/>
            </VBox>
        </StackPane>

        <VBox style="-fx-padding: 30 100;" spacing="30">
            <HBox spacing="20">
                <VBox style="-fx-background-color: #1a1f1e; -fx-background-radius: 10; -fx-min-width: 280;" spacing="10">
                    <ImageView fitWidth="280" fitHeight="200" style="-fx-background-radius: 10 10 0 0;"/>
                    <VBox style="-fx-padding: 15;">
                        <Label text="Nom de l'artefact" style="-fx-text-fill: #fff; -fx-font-weight: bold;"/>
                        <Label text="Description..." style="-fx-text-fill: #888;"/>
                        <Label text="Univers: Nom" style="-fx-text-fill: #18E3A4;"/>
                    </VBox>
                </VBox>
                <VBox style="-fx-background-color: #2a3139; -fx-background-radius: 10; -fx-min-width: 280; -fx-min-height: 300;" alignment="CENTER">
                    <Label text="+" style="-fx-text-fill: #18E3A4; -fx-font-size: 48;"/>
                    <Label text="Créer" style="-fx-text-fill: #18E3A4;"/>
                </VBox>
            </HBox>
        </VBox>

    </VBox>

</AnchorPane>