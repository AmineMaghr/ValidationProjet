<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.image.*?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.text.*?>

<AnchorPane xmlns="http://javafx.com/javafx" xmlns:fx="http://javafx.com/fxml" fx:controller="com.midgar.controller.SecurityForgotPasswordController" style="-fx-background-color: #0d1117;">

    <VBox alignment="CENTER" spacing="30" AnchorPane.leftAnchor="0" AnchorPane.rightAnchor="0" AnchorPane.topAnchor="0" AnchorPane.bottomAnchor="0">
        
        <HBox alignment="CENTER" style="-fx-background-color: #0b0f10; -fx-padding: 20;" maxWidth="Infinity">
            <Label text="MIDGAR" style="-fx-text-fill: #18E3A4; -fx-font-size: 28; -fx-font-weight: bold;"/>
        </HBox>

        <VBox style="-fx-background-color: #1a1f1e; -fx-padding: 40; -fx-background-radius: 10;" spacing="20" maxWidth="450">
            <Label text="Mot de passe oublié?" style="-fx-text-fill: #fff; -fx-font-size: 24; -fx-font-weight: bold;"/>
            <Label text="Entrez votre email et nous vous enverrons un lien pour réinitialiser votre mot de passe." style="-fx-text-fill: #888;" textAlignment="CENTER" wrapText="true"/>
            
            <VBox spacing="15">
                <VBox spacing="5">
                    <Label text="Email" style="-fx-text-fill: #b0b9b6;"/>
                    <TextField fx:id="emailField" promptText="votre@email.com" style="-fx-background-color: #0b0f10; -fx-text-fill: #fff; -fx-border-color: #2a3139; -fx-border-radius: 5; -fx-background-radius: 5; -fx-padding: 10;"/>
                </VBox>
            </VBox>

            <Button text="Envoyer le lien" style="-fx-background-color: #18E3A4; -fx-text-fill: #0b0f10; -fx-font-weight: bold; -fx-padding: 12 20; -fx-background-radius: 5;"/>

            <HBox spacing="5" alignment="CENTER">
                <Label text="Retour à la" style="-fx-text-fill: #b0b9b6;"/>
                <Button text="connexion" styleClass="link-button"/>
            </HBox>
        </VBox>

    </VBox>

</AnchorPane>