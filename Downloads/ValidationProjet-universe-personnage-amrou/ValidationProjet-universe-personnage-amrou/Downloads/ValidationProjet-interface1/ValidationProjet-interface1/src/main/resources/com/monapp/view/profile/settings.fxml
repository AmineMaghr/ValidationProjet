<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.image.*?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.text.*?>

<AnchorPane xmlns="http://javafx.com/javafx" xmlns:fx="http://javafx.com/fxml" fx:controller="com.midgar.controller.ProfileSettingsController" style="-fx-background-color: #0d1117;">

    <fx:include source="../partials/header.fxml" AnchorPane.leftAnchor="0" AnchorPane.rightAnchor="0" AnchorPane.topAnchor="0"/>

    <VBox spacing="0" AnchorPane.leftAnchor="0" AnchorPane.rightAnchor="0" AnchorPane.topAnchor="100">

        <StackPane style="-fx-background-color: #0b0f10; -fx-min-height: 150;">
            <VBox alignment="CENTER">
                <Label text="PARAMÈTRES" style="-fx-text-fill: #fff; -fx-font-size: 36; -fx-font-weight: bold;"/>
            </VBox>
        </StackPane>

        <HBox style="-fx-padding: 40 100;" spacing="40">
            <!-- Settings Menu -->
            <VBox spacing="10" minWidth="200">
                <Button text="Général" style="-fx-background-color: #18E3A4; -fx-text-fill: #0b0f10; -fx-alignment: CENTER_LEFT; -fx-padding: 12 15;"/>
                <Button text="Sécurité" style="-fx-background-color: #1a1f1e; -fx-text-fill: #fff; -fx-alignment: CENTER_LEFT; -fx-padding: 12 15;"/>
                <Button text="Confidentialité" style="-fx-background-color: #1a1f1e; -fx-text-fill: #fff; -fx-alignment: CENTER_LEFT; -fx-padding: 12 15;"/>
                <Button text="Notifications" style="-fx-background-color: #1a1f1e; -fx-text-fill: #fff; -fx-alignment: CENTER_LEFT; -fx-padding: 12 15;"/>
            </VBox>

            <!-- Settings Form -->
            <VBox spacing="20" HBox.hgrow="ALWAYS">
                <Label text="Paramètres généraux" style="-fx-text-fill: #fff; -fx-font-size: 20; -fx-font-weight: bold;"/>
                
                <VBox spacing="15">
                    <VBox spacing="5">
                        <Label text="Pseudo" style="-fx-text-fill: #b0b9b6;"/>
                        <TextField style="-fx-background-color: #1a1f1e; -fx-text-fill: #fff; -fx-border-color: #2a3139; -fx-border-radius: 5; -fx-padding: 10;"/>
                    </VBox>
                    
                    <VBox spacing="5">
                        <Label text="Email" style="-fx-text-fill: #b0b9b6;"/>
                        <TextField style="-fx-background-color: #1a1f1e; -fx-text-fill: #fff; -fx-border-color: #2a3139; -fx-border-radius: 5; -fx-padding: 10;"/>
                    </VBox>
                    
                    <VBox spacing="5">
                        <Label text="Bio" style="-fx-text-fill: #b0b9b6;"/>
                        <TextArea style="-fx-background-color: #1a1f1e; -fx-text-fill: #fff; -fx-border-color: #2a3139; -fx-background-radius: 5; -fx-padding: 10;" minHeight="100"/>
                    </VBox>

                    <Button text="Enregistrer" style="-fx-background-color: #18E3A4; -fx-text-fill: #0b0f10; -fx-font-weight: bold; -fx-padding: 12 20;"/>
                </VBox>
            </VBox>
        </HBox>

    </VBox>

</AnchorPane>