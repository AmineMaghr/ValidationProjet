<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox xmlns="http://javafx.com/javafx" xmlns:fx="http://javafx.com/fxml"
      fx:controller="com.example.app.controllers.ChatbotPanelController"
      spacing="10" style="-fx-padding: 15; -fx-background-color: #1a1f1e;">

    <Label text="🤖 Chat with Universe" style="-fx-text-fill: #18E3A4; -fx-font-size: 16px; -fx-font-weight: bold;"/>

    <HBox spacing="10">
        <Label text="Mode:" style="-fx-text-fill: #aaa;"/>
        <ComboBox fx:id="modeCombo" prefWidth="150"/>
    </HBox>

    <TextArea fx:id="chatArea"
              prefHeight="250"
              wrapText="true"
              editable="false"
              style="-fx-control-inner-background: #2a3139; -fx-text-fill: #fff; -fx-font-family: 'Courier New'; -fx-font-size: 12px;"/>

    <HBox spacing="10" alignment="CENTER_LEFT">
        <TextField fx:id="inputField"
                   promptText="Ask something..."
                   HBox.hgrow="ALWAYS"
                   style="-fx-control-inner-background: #2a3139; -fx-text-fill: #fff;"/>
        <Button fx:id="sendBtn"
                text="Send"
                prefWidth="80"
                style="-fx-background-color: #18E3A4; -fx-text-fill: #000; -fx-font-weight: bold;"/>
    </HBox>

</VBox>
